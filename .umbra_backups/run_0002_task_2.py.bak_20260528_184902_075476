import tkinter as tk

# Configuration settings
WINDOW_WIDTH = 800
WINDOW_HEIGHT = 600
RECTANGLE_SIZE = 40
MOVEMENT_STEP = 4
DRY_RUN = False  # Set to True for a dry run without opening the window

def main():
    if DRY_RUN:
        print("Dry run mode enabled. No GUI will be opened.")
        return

    root = tk.Tk()
    root.title("Arrow Key Movement")
    root.geometry(f"{WINDOW_WIDTH}x{WINDOW_HEIGHT}")

    canvas = tk.Canvas(root, width=WINDOW_WIDTH, height=WINDOW_HEIGHT)
    canvas.pack()

    # Calculate initial position to center the rectangle
    x0 = (WINDOW_WIDTH - RECTANGLE_SIZE) // 2
    y0 = (WINDOW_HEIGHT - RECTANGLE_SIZE) // 2
    x1 = x0 + RECTANGLE_SIZE
    y1 = y0 + RECTANGLE_SIZE

    player_rectangle = canvas.create_rectangle(x0, y0, x1, y1, fill="blue")

    def move_rectangle(event):
        if event.keysym == "Up":
            canvas.move(player_rectangle, 0, -MOVEMENT_STEP)
        elif event.keysym == "Down":
            canvas.move(player_rectangle, 0, MOVEMENT_STEP)
        elif event.keysym == "Left":
            canvas.move(player_rectangle, -MOVEMENT_STEP, 0)
        elif event.keysym == "Right":
            canvas.move(player_rectangle, MOVEMENT_STEP, 0)

    root.bind("<KeyPress>", move_rectangle)

    print("Game started. Use arrow keys to move the blue rectangle.")
    root.mainloop()

if __name__ == "__main__":
    main()
