import pandas as pd

class DatabaseManager:
    def __init__(self, db_path):
        """
        Initialize the DatabaseManager with a path to the database file.
        
        :param db_path: Path to the database file (e.g., CSV)
        """
        self.db_path = db_path
        self.dataframe = pd.read_csv(db_path)

    def insert_record(self, new_record):
        """
        Insert a new record into the database.
        
        :param new_record: A dictionary representing the new record to be inserted.
        """
        # Convert the new record dictionary to a DataFrame
        new_df = pd.DataFrame([new_record])
        
        # Handle missing data by filling NaN values with the column's mean or mode
        for column in new_df.columns:
            if self.dataframe[column].dtype == 'float64' or self.dataframe[column].dtype == 'int64':
                # Use mean for numerical columns
                new_df[column] = new_df[column].fillna(self.dataframe[column].mean())
            else:
                # Use mode for categorical columns
                mode_value = self.dataframe[column].mode()[0]
                new_df[column] = new_df[column].fillna(mode_value)
        
        # Append the new record to the existing dataframe
        self.dataframe = pd.concat([self.dataframe, new_df], ignore_index=True)
        
        # Save the updated dataframe back to the database file
        self.dataframe.to_csv(self.db_path, index=False)
        
        # Print a confirmation message with the inserted record details
        print(f"Record inserted successfully: {new_record}")

