import os
import shutil
from pathlib import Path
import sys

# Constants for paths and options
SOURCE_DIR = 'source_directory'
DESTINATION_DIR = 'destination_directory'
DRY_RUN = False  # Set to True for a dry run

def organize_files_by_extension(source, destination, dry_run=False):
    """
    Organizes files in the source directory by their extension into subdirectories in the destination directory.
    
    :param source: Path to the source directory
    :param destination: Path to the destination directory
    :param dry_run: If True, perform a dry run without moving files
    """
    # Ensure paths are Path objects
    source_path = Path(source)
    destination_path = Path(destination)

    # Check if source exists and is a directory
    if not source_path.exists() or not source_path.is_dir():
        print(f"Source directory '{source}' does not exist or is not a directory.")
        return

    # Create destination directory if it doesn't exist
    if not destination_path.exists():
        if dry_run:
            print(f"Dry run: Would create destination directory '{destination}'.")
        else:
            destination_path.mkdir(parents=True, exist_ok=True)
            print(f"Created destination directory '{destination}'.")

    # Process each file in the source directory
    for file_path in source_path.iterdir():
        if file_path.is_file():
            extension = file_path.suffix.lower()
            target_dir = destination_path / extension

            # Create target directory if it doesn't exist
            if not target_dir.exists():
                if dry_run:
                    print(f"Dry run: Would create directory '{target_dir}'.")
                else:
                    target_dir.mkdir(parents=True, exist_ok=True)
                    print(f"Created directory '{target_dir}'.")

            # Move file to the appropriate directory
            target_file_path = target_dir / file_path.name
            if dry_run:
                print(f"Dry run: Would move '{file_path}' to '{target_file_path}'.")
            else:
                shutil.move(str(file_path), str(target_file_path))
                print(f"Moved '{file_path}' to '{target_file_path}'.")

if __name__ == "__main__":
    # Parse command line arguments
    if len(sys.argv) > 1 and sys.argv[1] == '--dry-run':
        DRY_RUN = True

    organize_files_by_extension(SOURCE_DIR, DESTINATION_DIR, dry_run=DRY_RUN)
