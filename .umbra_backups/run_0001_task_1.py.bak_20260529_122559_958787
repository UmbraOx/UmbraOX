import os
from pathlib import Path

# Configuration options
SEARCH_DIRS = ['path/to/dir1', 'path/to/dir2']  # Paths to search for files
FILE_EXTENSIONS = ['.log', '.txt']  # File extensions to look for
DRY_RUN = False  # Set to True for a dry run without making changes
ERROR_KEYWORDS = ['error', 'fail', 'exception']  # Keywords to identify error messages

def find_error_messages(file_path):
    """Search for error messages in a file."""
    try:
        with open(file_path, 'r') as file:
            lines = file.readlines()
            for line_number, line in enumerate(lines, start=1):
                if any(keyword.lower() in line.lower() for keyword in ERROR_KEYWORDS):
                    print(f"Error found in {file_path} at line {line_number}:")
                    print(line.strip())
    except IOError as e:
        print(f"Error reading file {file_path}: {e}")

def search_directories(dry_run=False):
    """Search through directories for files and identify error messages."""
    for dir_path in SEARCH_DIRS:
        path = Path(dir_path)
        if not path.is_dir():
            print(f"Warning: Directory {path} does not exist.")
            continue
        print(f"Searching directory: {path}")
        for file_path in path.rglob('*'):
            if file_path.is_file() and any(file_path.suffix == ext for ext in FILE_EXTENSIONS):
                find_error_messages(file_path)
                if dry_run:
                    print("Dry run - no changes made.")
                else:
                    # Perform actual actions here if needed
                    pass

if __name__ == "__main__":
    search_directories(DRY_RUN)
