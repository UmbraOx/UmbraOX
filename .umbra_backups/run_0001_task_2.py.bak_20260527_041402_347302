import subprocess
import sys

def install_package(package_name):
    """Install a Python package using pip."""
    try:
        subprocess.check_call([sys.executable, "-m", "pip", "install", package_name])
    except subprocess.CalledProcessError as e:
        print(f"Failed to install {package_name}. Error: {e}")
        sys.exit(1)

def check_and_install_packages():
    """Check for and install necessary Python packages."""
    required_packages = ["requests", "beautifulsoup4", "json"]
    
    for package in required_packages:
        try:
            __import__(package)
            print(f"{package} is already installed.")
        except ImportError:
            print(f"{package} is not installed. Installing now...")
            install_package(package)

def main():
    """
    Main function to set up the Python environment and demonstrate usage of
    requests, BeautifulSoup, and json libraries.
    """
    check_and_install_packages()
    
    # Example usage of the libraries
    import requests
    from bs4 import BeautifulSoup
    import json

    try:
        response = requests.get("https://httpbin.org/get")
        response.raise_for_status()  # Raise an error for bad responses
        
        data = response.json()
        print("Data retrieved using requests:")
        print(json.dumps(data, indent=4))
        
        soup = BeautifulSoup("<html><body><h1>Hello, World!</h1></body></html>", "html.parser")
        print("\nParsed HTML using BeautifulSoup:")
        print(soup.h1.text)
    
    except requests.exceptions.RequestException as e:
        print(f"An error occurred during the request: {e}")
    except Exception as e:
        print(f"An unexpected error occurred: {e}")

if __name__ == "__main__":
    main()
