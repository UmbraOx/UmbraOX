import numpy as np
import matplotlib.pyplot as plt
from matplotlib.patches import Circle

def generate_cartoon_ice_cream():
    """
    Generates a cartoonish-style ice cream image using matplotlib.
    
    The ice cream is represented with a yellow circle (ice cream cone) and 
    a pink circle (ice cream scoop). A smiley face is added to make it more cartoonish.
    """
    try:
        # Create a new figure
        fig, ax = plt.subplots(figsize=(6, 6))
        
        # Draw the ice cream cone
        cone = Circle((0.5, 0.3), 0.2, color='yellow', edgecolor='black')
        ax.add_artist(cone)
        
        # Draw the ice cream scoop
        scoop = Circle((0.5, 0.6), 0.3, color='pink', edgecolor='black')
        ax.add_artist(scoop)
        
        # Add a smiley face to make it more cartoonish
        eye1 = Circle((0.4, 0.75), 0.02, color='black')
        eye2 = Circle((0.6, 0.75), 0.02, color='black')
        mouth = plt.Polygon([[0.35, 0.6], [0.5, 0.58], [0.65, 0.6]], fill=True, closed=True, edgecolor='black', facecolor='black')
        
        ax.add_artist(eye1)
        ax.add_artist(eye2)
        ax.add_patch(mouth)
        
        # Set the aspect to equal and remove axes
        ax.set_aspect('equal')
        ax.axis('off')
        
        # Show the plot
        plt.show()
    except Exception as e:
        print(f"An error occurred while generating the ice cream image: {e}")

# Run the function to generate the cartoonish ice cream image
generate_cartoon_ice_cream()
