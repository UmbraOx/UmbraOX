from flask import Flask, request, jsonify

app = Flask(__name__)

# Game state
player_health = 100
game_over = False

@app.route('/update_health', methods=['POST'])
def update_health():
    """
    Update the player's health.
    
    Request Body:
    {
        "health": int
    }
    
    Returns:
    {
        "message": str,
        "game_over": bool
    }
    """
    global player_health, game_over
    
    # Validate request data
    if not request.json or 'health' not in request.json:
        return jsonify({"error": "Invalid request"}), 400
    
    new_health = request.json['health']
    
    # Update health and check for game over condition
    player_health = max(0, new_health)
    game_over = player_health == 0
    
    if game_over:
        return jsonify({"message": "Game Over!", "game_over": True}), 200
    else:
        return jsonify({"message": f"Health updated to {player_health}", "game_over": False}), 200

@app.route('/restart', methods=['POST'])
def restart():
    """
    Restart the game.
    
    Returns:
    {
        "message": str
    }
    """
    global player_health, game_over
    
    # Reset game state
    player_health = 100
    game_over = False
    
    return jsonify({"message": "Game restarted"}), 200

@app.errorhandler(404)
def not_found_error(error):
    """
    Handle 404 Not Found errors.
    
    Returns:
    {
        "error": str
    }
    """
    return jsonify({'error': 'Resource not found'}), 404

@app.errorhandler(500)
def internal_error(error):
    """
    Handle 500 Internal Server Error.
    
    Returns:
    {
        "error": str
    }
    """
    return jsonify({'error': 'Internal server error'}), 500

if __name__ == '__main__':
    app.run(debug=True)
