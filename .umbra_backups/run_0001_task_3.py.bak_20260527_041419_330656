import requests

def fetch_news_html(url):
    """
    This function sends an HTTP GET request to the specified URL and returns the HTML content.
    
    Args:
    url (str): The URL of the news website to fetch the HTML from.
    
    Returns:
    str: The HTML content retrieved from the URL.
    
    Raises:
    requests.exceptions.RequestException: If there is an error during the HTTP request.
    """
    try:
        # Send a GET request to the specified URL
        response = requests.get(url)
        
        # Raise an exception if the request was unsuccessful
        response.raise_for_status()
        
        # Return the HTML content from the response
        return response.text
    except requests.exceptions.RequestException as e:
        # Print the error message and raise the exception to be handled by the caller
        print(f"Error fetching news HTML: {e}")
        raise

if __name__ == '__main__':
    # URL of the news website to fetch the HTML from
    news_url = 'https://news.example.com'
    
    try:
        # Fetch the HTML content from the news website
        html_content = fetch_news_html(news_url)
        
        # Print the first 1000 characters of the HTML content for a quick preview
        print(html_content[:1000])
    except Exception as e:
        # Handle any exceptions that may have occurred during execution
        print(f"An error occurred: {e}")
