from flask import Flask, request, jsonify, abort
import pygame

app = Flask(__name__)
pygame.init()

# Game settings
SCREEN_WIDTH, SCREEN_HEIGHT = 800, 600
PLAYER_SIZE = 50
FPS = 60

# Initialize Pygame screen
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
clock = pygame.time.Clock()

# Player position
player_pos = [SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2]

# Game state
game_over = False
win_condition_met = False

def reset_game():
    global player_pos, game_over, win_condition_met
    player_pos = [SCREEN_WIDTH // 2, SCREEN_HEIGHT // 2]
    game_over = False
    win_condition_met = False

@app.route('/move_player', methods=['POST'])
def move_player():
    """
    Move the player based on input direction.
    
    Request body should be a JSON object with 'direction' key:
    {
        "direction": "up" | "down" | "left" | "right"
    }
    
    Returns:
    - 200 OK: Player moved successfully
    - 400 Bad Request: Invalid direction or request format
    """
    data = request.get_json()
    if not data or 'direction' not in data:
        abort(400, description="Invalid request format")
    
    direction = data['direction']
    move_amount = 10
    
    if direction == "up":
        player_pos[1] -= move_amount
    elif direction == "down":
        player_pos[1] += move_amount
    elif direction == "left":
        player_pos[0] -= move_amount
    elif direction == "right":
        player_pos[0] += move_amount
    else:
        abort(400, description="Invalid direction")
    
    # Check for borders
    if player_pos[0] < 0:
        player_pos[0] = 0
    elif player_pos[0] > SCREEN_WIDTH - PLAYER_SIZE:
        player_pos[0] = SCREEN_WIDTH - PLAYER_SIZE
    
    if player_pos[1] < 0:
        player_pos[1] = 0
    elif player_pos[1] > SCREEN_HEIGHT - PLAYER_SIZE:
        player_pos[1] = SCREEN_HEIGHT - PLAYER_SIZE
    
    return jsonify({"status": "success", "player_position": player_pos}), 200

@app.route('/restart_game', methods=['POST'])
def restart_game():
    """
    Restart the game.
    
    Returns:
    - 200 OK: Game restarted successfully
    """
    reset_game()
    return jsonify({"status": "success"}), 200

@app.errorhandler(400)
def bad_request(error):
    """Handle Bad Request errors."""
    response = jsonify({'error': error.description})
    response.status_code = 400
    return response

@app.errorhandler(Exception)
def internal_error(error):
    """Handle other exceptions."""
    response = jsonify({'error': 'Internal server error'})
    response.status_code = 500
    return response

if __name__ == '__main__':
    app.run(debug=True, threaded=True)
