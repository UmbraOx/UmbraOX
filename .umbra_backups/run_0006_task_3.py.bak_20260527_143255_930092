import tkinter as tk

def main():
    """
    Main function to initialize the dashboard application.
    """
    # Create the main window
    root = tk.Tk()
    root.title("Dashboard")
    
    # Set the size of the window
    root.geometry("800x600")
    
    # Create a frame for the header
    header_frame = tk.Frame(root, bg='blue', height=100)
    header_frame.pack(fill=tk.X)
    
    # Add a label to the header
    header_label = tk.Label(header_frame, text="Dashboard", font=("Arial", 24), fg="white", bg="blue")
    header_label.pack(expand=True)
    
    # Create a frame for the main content area
    content_frame = tk.Frame(root, bg='lightgray')
    content_frame.pack(expand=True, fill=tk.BOTH)
    
    # Add some widgets to the content frame
    widget1 = tk.Label(content_frame, text="Widget 1", font=("Arial", 16), bg='white', padx=20, pady=20)
    widget1.grid(row=0, column=0, sticky=tk.NSEW)
    
    widget2 = tk.Label(content_frame, text="Widget 2", font=("Arial", 16), bg='lightblue', padx=20, pady=20)
    widget2.grid(row=0, column=1, sticky=tk.NSEW)
    
    widget3 = tk.Label(content_frame, text="Widget 3", font=("Arial", 16), bg='white', padx=20, pady=20)
    widget3.grid(row=1, column=0, sticky=tk.NSEW)
    
    widget4 = tk.Label(content_frame, text="Widget 4", font=("Arial", 16), bg='lightblue', padx=20, pady=20)
    widget4.grid(row=1, column=1, sticky=tk.NSEW)
    
    # Configure grid weights for responsive layout
    content_frame.columnconfigure(0, weight=1)
    content_frame.columnconfigure(1, weight=1)
    content_frame.rowconfigure(0, weight=1)
    content_frame.rowconfigure(1, weight=1)
    
    # Start the Tkinter event loop
    root.mainloop()

if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        print(f"An error occurred: {e}")
