import os
import curses

# Configuration constants
MAP_FILE = "map.txt"
DRY_RUN = False

def load_map(file_path):
    """Load map from a text file."""
    try:
        with open(file_path, 'r') as file:
            return [list(line.strip()) for line in file.readlines()]
    except FileNotFoundError:
        print(f"Error: The file {file_path} does not exist.")
        exit(1)
    except Exception as e:
        print(f"An error occurred while reading the file: {e}")
        exit(1)

def save_map(file_path, map_data):
    """Save map to a text file."""
    try:
        with open(file_path, 'w') as file:
            for row in map_data:
                file.write(''.join(row) + '\n')
    except Exception as e:
        print(f"An error occurred while writing the file: {e}")
        exit(1)

def initialize_curses(stdscr):
    """Initialize curses settings."""
    curses.curs_set(0)
    stdscr.nodelay(1)
    stdscr.timeout(100)

def draw_map(stdscr, map_data):
    """Draw the map on the screen."""
    for y, row in enumerate(map_data):
        for x, char in enumerate(row):
            stdscr.addch(y, x, ord(char))

def move_player(map_data, player_pos, direction):
    """Move the player in a given direction."""
    x, y = player_pos
    if direction == curses.KEY_UP and y > 0 and map_data[y-1][x] != '#':
        return (x, y-1)
    elif direction == curses.KEY_DOWN and y < len(map_data) - 1 and map_data[y+1][x] != '#':
        return (x, y+1)
    elif direction == curses.KEY_LEFT and x > 0 and map_data[y][x-1] != '#':
        return (x-1, y)
    elif direction == curses.KEY_RIGHT and x < len(map_data[0]) - 1 and map_data[y][x+1] != '#':
        return (x+1, y)
    return player_pos

def main(stdscr):
    """Main function for the game."""
    initialize_curses(stdscr)
    
    # Load or create a new map
    if os.path.exists(MAP_FILE) and not DRY_RUN:
        map_data = load_map(MAP_FILE)
    else:
        print("Creating a new map...")
        map_data = [
            list("# ##########"),
            list("#          #"),
            list("#          #"),
            list("#  P       #"),
            list("#          #"),
            list("# ##########")
        ]
    
    player_pos = (3, 2)  # Starting position of the player
    map_data[player_pos[1]][player_pos[0]] = 'P'
    
    while True:
        stdscr.clear()
        
        draw_map(stdscr, map_data)
        
        key = stdscr.getch()
        
        if key == ord('q'):
            break
        
        new_player_pos = move_player(map_data, player_pos, key)
        if new_player_pos != player_pos:
            map_data[player_pos[1]][player_pos[0]] = ' '
            map_data[new_player_pos[1]][new_player_pos[0]] = 'P'
            player_pos = new_player_pos
        
        stdscr.refresh()

if __name__ == "__main__":
    curses.wrapper(main)
