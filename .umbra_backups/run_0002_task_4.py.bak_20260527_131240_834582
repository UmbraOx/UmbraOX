from typing import Dict, List, Any, Optional

class AgentCapability:
    def __init__(self, name: str, description: str, enabled: bool):
        self.name = name
        self.description = description
        self.enabled = enabled

    def to_dict(self) -> Dict[str, Any]:
        return {
            'name': self.name,
            'description': self.description,
            'enabled': self.enabled
        }

class AgentCapabilityMatrix:
    """
    This class represents a matrix of agent capabilities.
    It allows adding, updating, and retrieving agent capabilities.
    """
    
    def __init__(self):
        """
        Initialize the AgentCapabilityMatrix with an empty list of capabilities.
        """
        self.capabilities: List[AgentCapability] = []

    def add_capability(self, capability: AgentCapability) -> None:
        """
        Add a new capability to the matrix.

        :param capability: The AgentCapability instance to add.
        :raises ValueError: If the capability already exists in the matrix.
        """
        if any(c.name == capability.name for c in self.capabilities):
            raise ValueError(f"Capability '{capability.name}' already exists.")
        self.capabilities.append(capability)

    def update_capability(self, name: str, enabled: Optional[bool] = None) -> None:
        """
        Update an existing capability's status.

        :param name: The name of the capability to update.
        :param enabled: New enabled status for the capability (if provided).
        :raises KeyError: If the capability does not exist in the matrix.
        """
        for capability in self.capabilities:
            if capability.name == name:
                if enabled is not None:
                    capability.enabled = enabled
                return
        raise KeyError(f"Capability '{name}' not found.")

    def get_capability(self, name: str) -> AgentCapability:
        """
        Retrieve a capability by its name.

        :param name: The name of the capability to retrieve.
        :return: The AgentCapability instance.
        :raises KeyError: If the capability does not exist in the matrix.
        """
        for capability in self.capabilities:
            if capability.name == name:
                return capability
        raise KeyError(f"Capability '{name}' not found.")

    def to_dict(self) -> Dict[str, List[Dict[str, Any]]]:
        """
        Return a dictionary representation of the agent capabilities.

        :return: A dictionary with capabilities as a list of dictionaries.
        """
        return {
            'capabilities': [c.to_dict() for c in self.capabilities]
        }

# Example usage:
if __name__ == "__main__":
    capability_matrix = AgentCapabilityMatrix()
    capability_matrix.add_capability(AgentCapability("LanguageUnderstanding", "Ability to understand human language.", True))
    capability_matrix.add_capability(AgentCapability("DataProcessing", "Ability to process and analyze data.", False))

    print(capability_matrix.to_dict())
    
    try:
        capability_matrix.update_capability("DataProcessing", enabled=True)
        print(capability_matrix.get_capability("DataProcessing").to_dict())
    except (ValueError, KeyError) as e:
        print(f"An error occurred: {e}")
