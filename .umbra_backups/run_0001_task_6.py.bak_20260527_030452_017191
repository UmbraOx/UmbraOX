import pandas as pd

class DatabaseManager:
    def __init__(self):
        # Initialize with an empty DataFrame
        self.data = pd.DataFrame()

    def load_data(self, file_path):
        """Load data from a CSV file into the DataFrame."""
        self.data = pd.read_csv(file_path)

    def update_record(self, record_id, updates):
        """
        Update an existing record in the database.

        Parameters:
        - record_id: The unique identifier for the record to update.
        - updates: A dictionary where keys are column names and values are the new data.

        Returns:
        - None
        """
        # Check if the record exists
        if record_id not in self.data.index:
            print(f"Record with ID {record_id} does not exist.")
            return

        # Iterate over the updates dictionary
        for column, value in updates.items():
            # Check if the column exists in the DataFrame
            if column not in self.data.columns:
                print(f"Column '{column}' does not exist in the database.")
                continue

            # Update the record with the new value
            self.data.at[record_id, column] = value

        # Handle missing data gracefully
        self.handle_missing_data()

        # Print a summary of the updated record
        print("\nUpdated Record:")
        print(self.data.loc[[record_id]])

    def handle_missing_data(self):
        """
        Handle missing data in the DataFrame.

        - Fill numeric columns with their mean.
        - Fill categorical columns with the mode.
        """
        for column in self.data.columns:
            if self.data[column].isnull().any():
                if pd.api.types.is_numeric_dtype(self.data[column]):
                    # Fill missing values with the mean of the column
                    mean_value = self.data[column].mean()
                    self.data[column].fillna(mean_value, inplace=True)
                    print(f"Filled missing values in '{column}' with mean: {mean_value}")
                elif pd.api.types.is_object_dtype(self.data[column]) or pd.api.types.is_categorical_dtype(self.data[column]):
                    # Fill missing values with the mode of the column
                    mode_value = self.data[column].mode()[0]
                    self.data[column].fillna(mode_value, inplace=True)
                    print(f"Filled missing values in '{column}' with mode: {mode_value}")

    def save_data(self, file_path):
        """Save the updated DataFrame back to a CSV file."""
        self.data.to_csv(file_path, index=False)

# Example usage:
if __name__ == "__main__":
    db_manager = DatabaseManager()
    db_manager.load_data("example.csv")
    
    # Update record with ID 1
    updates = {"Age": 30, "Salary": None}
    db_manager.update_record(1, updates)
    
    db_manager.save_data("updated_example.csv")
