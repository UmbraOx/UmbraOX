from flask import Flask, request, jsonify

app = Flask(__name__)

# Simulated game state
game_over = False

@app.route('/is_game_over', methods=['GET'])
def is_game_over():
    """
    Check if the game is over.
    
    Returns:
        JSON response with a boolean indicating if the game is over.
    """
    return jsonify({'gameOver': game_over})

@app.route('/restart_game', methods=['POST'])
def restart_game():
    """
    Restart the game when the 'R' key is pressed after game over.
    
    Request Validation:
        - Only accepts POST requests
    
    Returns:
        JSON response with a success message if the game is restarted successfully.
        
    Raises:
        405 Method Not Allowed: If the request method is not POST
    """
    global game_over
    
    # Check if the request method is POST
    if request.method != 'POST':
        return jsonify({'error': 'Method not allowed'}), 405
    
    # Reset the game state
    game_over = False
    
    return jsonify({'message': 'Game restarted successfully'})

if __name__ == '__main__':
    app.run(debug=True)
