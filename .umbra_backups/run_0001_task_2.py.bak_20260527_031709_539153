import requests
from bs4 import BeautifulSoup
import json

def setup_environment():
    """
    This function checks if the necessary libraries are installed.
    If any library is missing, it raises an ImportError.
    """
    try:
        # Importing requests to check its availability
        import requests
    except ImportError as e:
        raise ImportError("The 'requests' library is not installed. Please install it using pip.") from e

    try:
        # Importing BeautifulSoup from bs4 to check its availability
        from bs4 import BeautifulSoup
    except ImportError as e:
        raise ImportError("The 'BeautifulSoup' library (bs4) is not installed. Please install it using pip.") from e

    try:
        # Importing json to check its availability
        import json
    except ImportError as e:
        raise ImportError("The 'json' library is not available in this Python environment.") from e

    print("All necessary libraries are installed and ready to use.")

def main():
    """
    Main function to execute the setup process.
    """
    try:
        setup_environment()
    except ImportError as e:
        print(f"Error: {e}")
    else:
        print("Environment is set up successfully.")

if __name__ == "__main__":
    main()
