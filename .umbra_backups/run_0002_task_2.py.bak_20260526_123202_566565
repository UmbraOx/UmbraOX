import pandas as pd

def read_csv_and_generate_stats(file_path):
    """
    Reads a CSV file and generates summary statistics.

    Parameters:
    file_path (str): Path to the CSV file.

    Returns:
    None
    """
    try:
        # Read the CSV file into a DataFrame
        df = pd.read_csv(file_path)
        
        # Generate and print summary statistics
        print("Summary Statistics:")
        print(df.describe())
    
    except FileNotFoundError:
        print(f"Error: The file '{file_path}' was not found.")
    except pd.errors.EmptyDataError:
        print(f"Error: The file '{file_path}' is empty.")
    except pd.errors.ParserError:
        print(f"Error: The file '{file_path}' has an incorrect format.")
    except Exception as e:
        print(f"An unexpected error occurred: {e}")

if __name__ == "__main__":
    import sys
    
    if len(sys.argv) != 2:
        print("Usage: python umbra.py <path_to_csv_file>")
    else:
        file_path = sys.argv[1]
        read_csv_and_generate_stats(file_path)
