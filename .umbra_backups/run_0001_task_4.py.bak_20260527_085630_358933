"""
gui_file_browser.py - A GUI-based file browser for navigating the directory tree at C:\\Umbra\\workspaces\\,
previewing Python files, downloading them, and displaying their metadata.
"""

import os
import pandas as pd
from tkinter import Tk, Label, Button, Listbox, END, filedialog, messagebox
from tkinter.ttk import Treeview
import webbrowser

class FileBrowserApp:
    def __init__(self, root):
        self.root = root
        self.root.title("File Browser")
        
        # Initialize the GUI components
        self.tree = Treeview(root)
        self.tree.pack(expand=True, fill='both')
        self.tree.heading('#0', text='Directory Structure')
        self.populate_tree('C:\\Umbra\\workspaces\\')

    def populate_tree(self, directory):
        """Populate the tree view with directories and files."""
        for entry in os.listdir(directory):
            full_path = os.path.join(directory, entry)
            node_id = self.tree.insert('', 'end', text=entry, open=False)
            
            if os.path.isdir(full_path):
                # Recursively populate subdirectories
                self.populate_tree(full_path)
                self.tree.item(node_id, tags=('directory',))
            else:
                self.tree.item(node_id, tags=('file',))

    def preview_file(self):
        """Preview the selected Python file in a web browser."""
        try:
            selected_item = self.tree.selection()[0]
            item_text = self.tree.item(selected_item, 'text')
            if os.path.isfile(item_text) and item_text.endswith('.py'):
                with open(item_text, 'r') as file:
                    content = file.read()
                # Save content to a temporary HTML file and open in browser
                with open('temp_preview.html', 'w') as temp_file:
                    temp_file.write(f'<pre>{content}</pre>')
                webbrowser.open_new_tab('temp_preview.html')
            else:
                messagebox.showwarning("File Format", "Please select a Python (.py) file.")
        except IndexError:
            messagebox.showwarning("Selection", "No file selected.")

    def download_file(self):
        """Download the selected file."""
        try:
            selected_item = self.tree.selection()[0]
            item_text = self.tree.item(selected_item, 'text')
            if os.path.isfile(item_text):
                save_path = filedialog.asksaveasfilename(defaultextension=os.path.splitext(item_text)[1],
                                                        initialfile=item_text)
                if save_path:
                    with open(item_text, 'rb') as src_file:
                        with open(save_path, 'wb') as dst_file:
                            dst_file.write(src_file.read())
            else:
                messagebox.showwarning("File Selection", "Please select a file to download.")
        except IndexError:
            messagebox.showwarning("Selection", "No file selected.")

    def show_metadata(self):
        """Display metadata of the selected file."""
        try:
            selected_item = self.tree.selection()[0]
            item_text = self.tree.item(selected_item, 'text')
            if os.path.isfile(item_text):
                stats = os.stat(item_text)
                metadata = {
                    'File Name': item_text,
                    'Size (bytes)': stats.st_size,
                    'Last Modified': stats.st_mtime,
                    'Last Accessed': stats.st_atime
                }
                messagebox.showinfo("Metadata", '\n'.join(f"{k}: {v}" for k, v in metadata.items()))
            else:
                messagebox.showwarning("File Selection", "Please select a file to view metadata.")
        except IndexError:
            messagebox.showwarning("Selection", "No file selected.")

if __name__ == "__main__":
    root = Tk()
    app = FileBrowserApp(root)
    
    # Add buttons for previewing, downloading, and showing metadata
    Button(root, text="Preview Python File", command=app.preview_file).pack(pady=5)
    Button(root, text="Download File", command=app.download_file).pack(pady=5)
    Button(root, text="Show Metadata", command=app.show_metadata).pack(pady=5)

    root.mainloop()
