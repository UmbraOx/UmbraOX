import pandas as pd

# Step 1: Load the data into a DataFrame
# Replace 'data.csv' with your actual file path
df = pd.read_csv('data.csv')

# Step 2: Display basic information about the DataFrame
print("Basic Information:")
print(df.info())

# Step 3: Check for missing values and handle them
missing_values = df.isnull().sum()
print("\nMissing Values in Each Column:")
print(missing_values)

# Handling missing data (example: filling with mean for numeric columns)
numeric_cols = df.select_dtypes(include=['float64', 'int64']).columns
df[numeric_cols] = df[numeric_cols].fillna(df[numeric_cols].mean())

# Step 4: Detect column types
print("\nColumn Types:")
print(df.dtypes)

# Step 5: Perform basic statistical analysis
print("\nDescriptive Statistics:")
print(df.describe(include='all'))

# Step 6: Print a sample of the data
print("\nSample Data:")
print(df.head())

# Additional Analysis (Example: Correlation Matrix)
correlation_matrix = df.corr()
print("\nCorrelation Matrix:")
print(correlation_matrix)

# Save cleaned and analyzed data to a new CSV file
df.to_csv('cleaned_data.csv', index=False)
