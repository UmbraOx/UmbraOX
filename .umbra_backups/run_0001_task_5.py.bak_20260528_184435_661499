import time
import os

def clear_screen():
    """Clears the console screen."""
    os.system('cls' if os.name == 'nt' else 'clear')

def display_game(health, timer):
    """
    Displays the current game state with health and timer.
    
    :param health: Current player health (integer).
    :param timer: Remaining time in seconds (float).
    """
    clear_screen()
    print(f"Health: {health} ♥")
    print(f"Time Left: {timer:.1f} sec")

def main():
    """Main game loop."""
    try:
        initial_health = 10
        health = initial_health
        timer_duration = 10.0
        start_time = time.time()

        while True:
            current_time = time.time()
            elapsed_time = current_time - start_time
            remaining_timer = max(0, timer_duration - elapsed_time)

            display_game(health, remaining_timer)

            if remaining_timer <= 0:
                print("You win! Timer reached zero.")
                break

            user_input = input("Enter 'hit' to reduce health or 'exit' to quit: ").strip().lower()
            
            if user_input == 'hit':
                health -= 1
                if health <= 0:
                    print("Game Over! Health reached zero.")
                    break
            elif user_input == 'exit':
                print("Exiting game.")
                break

    except KeyboardInterrupt:
        print("\nGame interrupted by user.")

if __name__ == "__main__":
    main()
