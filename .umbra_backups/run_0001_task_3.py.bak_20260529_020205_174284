import pandas as pd

# Load the dataset
data = pd.read_csv('data.csv')

# Initialize an empty list to store bug reports
bug_reports = []

# Function to generate a formatted bug report
def generate_bug_report(line_number, severity, issue_description):
    return f"Line {line_number}: Severity {severity} - {issue_description}"

# Check for missing data
missing_data = data.isnull().sum()
for column, count in missing_data.items():
    if count > 0:
        bug_reports.append(generate_bug_report(-1, 'High', f'Missing data detected in column "{column}" with {count} missing values'))

# Detect incorrect data types
data_types = data.dtypes
for column, dtype in data_types.items():
    expected_type = 'float64' if dtype == float else 'int64'
    if dtype != expected_type:
        bug_reports.append(generate_bug_report(-1, 'Medium', f'Incorrect data type detected in column "{column}". Expected {expected_type}, but got {dtype}'))

# Perform statistical analysis and check for anomalies
for column in data.select_dtypes(include=['number']).columns:
    mean = data[column].mean()
    std_dev = data[column].std()
    lower_bound = mean - 3 * std_dev
    upper_bound = mean + 3 * std_dev
    
    outliers = data[(data[column] < lower_bound) | (data[column] > upper_bound)]
    if not outliers.empty:
        bug_reports.append(generate_bug_report(-1, 'Low', f'Outliers detected in column "{column}"'))

# Print the bug report
if bug_reports:
    print("Bug Report:")
    for report in bug_reports:
        print(report)
else:
    print("No issues found in the dataset.")
