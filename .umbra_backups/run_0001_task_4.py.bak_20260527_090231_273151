class Player:
    """
    A class representing the player in a game.
    
    Attributes:
        name (str): The name of the player.
        health (int): The current health points of the player.
    """

    def __init__(self, name):
        """
        Initializes a new player with the given name and sets the initial health to 3.
        
        Args:
            name (str): The name of the player.
        """
        self.name = name
        self.health = 3

    def display_health(self):
        """
        Displays the current health points of the player on the screen.
        """
        print(f"{self.name}'s Health: [{'#' * self.health}{' ' * (3 - self.health)}]")

    def take_damage(self, amount=1):
        """
        Reduces the player's health by a specified amount. The health cannot drop below 0.
        
        Args:
            amount (int): The amount of damage to inflict on the player.
        """
        if amount < 0:
            raise ValueError("Damage amount cannot be negative.")
        
        self.health = max(0, self.health - amount)
        self.display_health()

def main():
    """
    Main function to create a player and simulate taking damage.
    """
    player_name = input("Enter the player's name: ")
    player = Player(player_name)

    # Simulate taking damage
    while True:
        try:
            damage_input = input(f"How much damage should {player.name} take? (0 to exit): ")
            if damage_input == '0':
                break
            damage = int(damage_input)
            player.take_damage(damage)
        except ValueError as e:
            print(f"Invalid input: {e}. Please enter a valid integer.")

if __name__ == "__main__":
    main()
