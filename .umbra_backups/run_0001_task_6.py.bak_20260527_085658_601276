import os
import subprocess
import webbrowser
from flask import Flask, jsonify, request
from flask_cors import CORS

# Function to check if a package is installed
def is_package_installed(package):
    try:
        __import__(package)
        return True
    except ImportError:
        return False

# Install required packages if not present
required_packages = ['flask', 'flask-cors']
for package in required_packages:
    if not is_package_installed(package):
        print(f"Installing {package}...")
        subprocess.check_call(['pip', 'install', package])

app = Flask(__name__)
CORS(app)

# Define a route with request validation and error handling
@app.route('/api/data', methods=['POST'])
def handle_data():
    """
    Handle POST requests to /api/data.
    
    Expects JSON data in the format:
    {
        "key1": "value1",
        "key2": "value2"
    }
    
    Returns a JSON response with status 200 on success,
    or an appropriate error message and status code on failure.
    """
    try:
        # Validate request data
        data = request.get_json()
        if not isinstance(data, dict):
            return jsonify({'error': 'Invalid data format'}), 400
        
        # Process the data (example: just echo it back)
        response_data = {
            "received": data,
            "status": "success"
        }
        
        return jsonify(response_data), 200
    
    except Exception as e:
        return jsonify({'error': str(e)}), 500

if __name__ == '__main__':
    # Start the Flask server on port 7860
    print("Starting the GUI server on http://localhost:7860")
    port = 7860
    
    # Open the browser automatically
    webbrowser.open(f'http://localhost:{port}')
    
    # Run the app, keep running until Ctrl+C is pressed
    app.run(port=port)
