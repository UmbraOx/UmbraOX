import requests
from flask import Flask, request, jsonify
import os

app = Flask(__name__)
API_URL = "http://localhost:7861/sdapi/v1/txt2img"
IMAGE_SAVE_PATH = r"C:\Umbra\workspaces\images"

# Ensure the image save directory exists
os.makedirs(IMAGE_SAVE_PATH, exist_ok=True)

def validate_input(prompt):
    """Validate input prompt."""
    if not isinstance(prompt, str) or not prompt.strip():
        raise ValueError("Prompt must be a non-empty string.")
    return True

@app.route('/generate_image', methods=['POST'])
def generate_image():
    """
    Route to generate an image using Stable Diffusion API.
    
    Request JSON:
    {
        "prompt": "A beautiful sunset over the ocean"
    }
    
    Returns:
    JSON response with status and message.
    """
    try:
        data = request.get_json()
        
        # Validate input
        if not validate_input(data.get('prompt')):
            return jsonify({'status': 'error', 'message': 'Invalid prompt'}), 400
        
        # Prepare payload for API call
        payload = {
            "prompt": data['prompt'],
            "steps": 50,
            "cfg_scale": 7.0,
            "width": 512,
            "height": 512,
            "negative_prompt": "",
            "seed": -1,
            "sampler_index": "Euler a"
        }
        
        # Call Stable Diffusion API
        response = requests.post(API_URL, json=payload)
        if response.status_code != 200:
            return jsonify({'status': 'error', 'message': 'Failed to generate image'}), 500
        
        result = response.json()
        
        # Save the generated image
        if not os.path.exists(IMAGE_SAVE_PATH):
            os.makedirs(IMAGE_SAVE_PATH)
        
        image_path = os.path.join(IMAGE_SAVE_PATH, f"{data['prompt'].replace(' ', '_')}.png")
        with open(image_path, "wb") as f:
            f.write(requests.get(result["images"][0]).content)
        
        return jsonify({'status': 'success', 'message': f'Image saved to {image_path}'}), 200
    
    except Exception as e:
        app.logger.error(f"Error generating image: {e}")
        return jsonify({'status': 'error', 'message': str(e)}), 500

if __name__ == '__main__':
    app.run(debug=True)
