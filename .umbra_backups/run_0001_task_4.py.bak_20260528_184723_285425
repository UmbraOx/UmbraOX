class RedSquareEnemy:
    """
    A class representing a red square enemy object that moves towards the player.
    
    Attributes:
        x (int): The x-coordinate of the enemy's top-left corner.
        y (int): The y-coordinate of the enemy's top-left corner.
        width (int): The width of the enemy.
        height (int): The height of the enemy.
        speed (int): The speed at which the enemy moves towards the player.
    """
    
    def __init__(self, x: int, y: int):
        """
        Initializes a new instance of RedSquareEnemy.
        
        Args:
            x (int): The initial x-coordinate of the enemy's top-left corner.
            y (int): The initial y-coordinate of the enemy's top-left corner.
        """
        self.x = x
        self.y = y
        self.width = 40
        self.height = 40
        self.speed = 3
    
    def move_towards_player(self, player_x: int, player_y: int):
        """
        Moves the enemy towards the player.
        
        Args:
            player_x (int): The x-coordinate of the player's top-left corner.
            player_y (int): The y-coordinate of the player's top-left corner.
        """
        if self.x < player_x:
            self.x += self.speed
        elif self.x > player_x:
            self.x -= self.speed
        
        if self.y < player_y:
            self.y += self.speed
        elif self.y > player_y:
            self.y -= self.speed
    
    def check_collision(self, player: 'Player') -> bool:
        """
        Checks for collision between the enemy and the player.
        
        Args:
            player (Player): The player object to check collision with.
        
        Returns:
            bool: True if a collision occurs, False otherwise.
        """
        # Check if any of the corners of the enemy are within the player's rectangle
        return not (self.x + self.width < player.x or 
                    self.y + self.height < player.y or 
                    self.x > player.x + player.width or 
                    self.y > player.y + player.height)
    
    def to_dict(self) -> dict:
        """
        Converts the enemy's attributes to a dictionary.
        
        Returns:
            dict: A dictionary containing the enemy's attributes.
        """
        return {
            'x': self.x,
            'y': self.y,
            'width': self.width,
            'height': self.height,
            'speed': self.speed
        }

class Player:
    """
    A simple class representing a player with health and invincibility status.
    
    Attributes:
        x (int): The x-coordinate of the player's top-left corner.
        y (int): The y-coordinate of the player's top-left corner.
        width (int): The width of the player.
        height (int): The height of the player.
        health (int): The current health of the player.
        invincibility_frames (int): The number of frames remaining for invincibility.
    """
    
    def __init__(self, x: int, y: int):
        """
        Initializes a new instance of Player.
        
        Args:
            x (int): The initial x-coordinate of the player's top-left corner.
            y (int): The initial y-coordinate of the player's top-left corner.
        """
        self.x = x
        self.y = y
        self.width = 40
        self.height = 40
        self.health = 3
        self.invincibility_frames = 0
    
    def take_damage(self):
        """
        Decreases the player's health by 1 and sets invincibility frames.
        """
        if self.invincibility_frames == 0:
            self.health -= 1
            self.invincibility_frames = 90
    
    def update_invincibility(self):
        """
        Updates the invincibility status of the player.
        """
        if self.invincibility_frames > 0:
            self.invincibility_frames -= 1

# Example usage
if __name__ == "__main__":
    player = Player(200, 200)
    enemy = RedSquareEnemy(50, 50)

    # Simulate a game loop
    for _ in range(100):
        enemy.move_towards_player(player.x, player.y)
        
        if enemy.check_collision(player):
            player.take_damage()
        
        player.update_invincibility()

        print(f"Player Health: {player.health}, Invincibility Frames: {player.invincibility_frames}")
