import tkinter as tk
from tkinter import messagebox, filedialog
import speech_recognition as sr

class VoiceInputApp:
    def __init__(self, root):
        self.root = root
        self.root.title("Voice Input GUI")
        
        self.label = tk.Label(root, text="Enter or speak your prompt:")
        self.label.pack(pady=10)
        
        self.text_entry = tk.Text(root, height=5, width=40)
        self.text_entry.pack(pady=10)
        
        self.speech_button = tk.Button(root, text="Speak", command=self.record_speech)
        self.speech_button.pack(side=tk.LEFT, padx=10)
        
        self.submit_button = tk.Button(root, text="Submit", command=self.submit_prompt)
        self.submit_button.pack(side=tk.RIGHT, padx=10)
        
    def record_speech(self):
        recognizer = sr.Recognizer()
        microphone = sr.Microphone()
        
        try:
            with microphone as source:
                messagebox.showinfo("Recording", "Start speaking now...")
                audio = recognizer.listen(source, timeout=5, phrase_time_limit=10)
            
            try:
                prompt = recognizer.recognize_google(audio)
                self.text_entry.delete(1.0, tk.END)
                self.text_entry.insert(tk.END, prompt)
            except sr.UnknownValueError:
                messagebox.showerror("Recognition Error", "Google Speech Recognition could not understand audio.")
            except sr.RequestError as e:
                messagebox.showerror("Request Error", f"Could not request results from Google Speech Recognition service; {e}")
        
        except Exception as e:
            messagebox.showerror("Microphone Error", f"An error occurred while accessing the microphone: {e}")

    def submit_prompt(self):
        prompt = self.text_entry.get(1.0, tk.END).strip()
        if not prompt:
            messagebox.showwarning("Empty Prompt", "Please enter or speak a prompt.")
            return
        
        # Simulate sending the prompt to a pipeline
        print(f"Sending prompt to pipeline: {prompt}")
        
        # Clear the text entry for the next input
        self.text_entry.delete(1.0, tk.END)

if __name__ == "__main__":
    root = tk.Tk()
    app = VoiceInputApp(root)
    root.mainloop()
