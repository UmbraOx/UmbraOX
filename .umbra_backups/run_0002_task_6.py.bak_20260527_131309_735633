import pytest
from unittest.mock import MagicMock, patch
from agent_capability_matrix_module import AgentCapabilityMatrix

# Mocking external dependencies
@pytest.fixture
def mock_external_service():
    with patch('agent_capability_matrix_module.ExternalService') as MockExternalService:
        instance = MockExternalService.return_value
        yield instance

# Test for the main happy path
def test_agent_capability_matrix_happy_path(mock_external_service):
    # Arrange
    matrix = AgentCapabilityMatrix()
    
    # Set up mock behavior
    mock_external_service.get_capabilities.return_value = ['capability1', 'capability2']
    
    # Act
    capabilities = matrix.get_capabilities()
    
    # Assert
    assert capabilities == ['capability1', 'capability2'], "The capabilities should match the expected list"

# Test for error/edge case
def test_agent_capability_matrix_no_capabilities(mock_external_service):
    # Arrange
    matrix = AgentCapabilityMatrix()
    
    # Set up mock behavior
    mock_external_service.get_capabilities.return_value = []
    
    # Act
    capabilities = matrix.get_capabilities()
    
    # Assert
    assert capabilities == [], "The capabilities should be an empty list if none are found"
