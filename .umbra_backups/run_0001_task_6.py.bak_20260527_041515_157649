import pandas as pd

# Sample JSON data
json_data = '''
[
    {"name": "Alice", "age": 25, "city": "New York"},
    {"name": "Bob", "age": None, "city": "Los Angeles"},
    {"name": "Charlie", "age": 30, "city": None}
]
'''

# Load JSON data into a pandas DataFrame
df = pd.read_json(json_data)

# Display the initial DataFrame
print("Initial DataFrame:")
print(df)
print("\n")

# Handle missing data gracefully
# Fill missing values with appropriate defaults
df['age'].fillna(0, inplace=True)  # Assuming age cannot be None and setting default to 0
df['city'].fillna('Unknown', inplace=True)  # Filling unknown city as 'Unknown'

# Display DataFrame after handling missing data
print("DataFrame after handling missing data:")
print(df)
print("\n")

# Detect column types
print("Column Types:")
for col in df.columns:
    print(f"{col}: {df[col].dtype}")
print("\n")

# Save the DataFrame to a JSON file
output_file_path = 'data.json'
df.to_json(output_file_path, orient='records', indent=4)

# Print success message
print(f"Data has been saved to {output_file_path}")
