import pandas as pd

# Load the dataset
data = pd.read_csv('your_dataset.csv')

# Display basic information about the dataset
print("Dataset Information:")
print(data.info())
print("\n")

# Display the first few rows of the dataset
print("First Few Rows of the Dataset:")
print(data.head())
print("\n")

# Handle missing data
# Check for missing values in each column
missing_values = data.isnull().sum()
print("Missing Values in Each Column:")
print(missing_values)
print("\n")

# Drop columns with a high percentage of missing values (e.g., > 50%)
threshold = len(data) * 0.5
data.dropna(thresh=threshold, axis=1, inplace=True)
print(f"Dropped columns with more than {100 - (threshold / len(data))}% missing values.")
print("\n")

# Fill remaining missing values with the mean of the column for numerical data
numerical_columns = data.select_dtypes(include=['number']).columns
data[numerical_columns] = data[numerical_columns].fillna(data[numerical_columns].mean())
print("Filled missing values in numerical columns with their respective means.")
print("\n")

# Fill remaining missing values with the mode of the column for categorical data
categorical_columns = data.select_dtypes(include=['object']).columns
data[categorical_columns] = data[categorical_columns].fillna(data[categorical_columns].mode().iloc[0])
print("Filled missing values in categorical columns with their respective modes.")
print("\n")

# Detect and convert column types if necessary
# Convert object type columns that represent numbers to numeric type
for col in data.columns:
    try:
        pd.to_numeric(data[col], errors='raise')
        data[col] = pd.to_numeric(data[col])
        print(f"Converted column '{col}' to numeric.")
    except ValueError:
        pass

print("\n")

# Display the final dataset information
print("Final Dataset Information:")
print(data.info())
print("\n")

# Display the first few rows of the preprocessed dataset
print("First Few Rows of the Preprocessed Dataset:")
print(data.head())
