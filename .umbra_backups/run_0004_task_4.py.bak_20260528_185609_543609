from flask import Flask, jsonify, request, abort
from pydantic import BaseModel, ValidationError

app = Flask(__name__)

# Sample data
items = [
    {"id": 1, "name": "Item 1", "price": 10.99},
    {"id": 2, "name": "Item 2", "price": 5.49}
]

class Item(BaseModel):
    id: int
    name: str
    price: float

@app.route('/api/items', methods=['GET'])
def get_items():
    """
    Retrieve a list of items.

    Returns:
        JSON response with a list of item objects.
    """
    try:
        # Validate query parameters
        params = request.args.to_dict()
        if not all(isinstance(value, str) for value in params.values()):
            raise ValueError("Query parameters must be strings.")
        
        # Filter items based on query parameters
        filtered_items = [item for item in items if all(item.get(key) == value for key, value in params.items())]
        
        return jsonify({"items": filtered_items}), 200
    
    except ValidationError as e:
        app.logger.error(f"Validation error: {e}")
        return jsonify({"error": "Invalid request data"}), 400
    except Exception as e:
        app.logger.error(f"An unexpected error occurred: {e}")
        return jsonify({"error": "Internal server error"}), 500

if __name__ == '__main__':
    app.run(debug=True)
