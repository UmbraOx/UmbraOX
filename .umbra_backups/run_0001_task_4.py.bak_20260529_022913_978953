import re

def refine_sketch(sketch):
    """
    Refine a rough sketch into a more detailed drawing.
    
    Args:
        sketch (str): A string representing the rough sketch.
        
    Returns:
        str: A refined version of the sketch.
        
    Raises:
        ValueError: If the input is not a valid string.
    """
    if not isinstance(sketch, str):
        raise ValueError("Input must be a string.")
    
    # Basic refinement rules
    refinements = {
        'dot': 'circle',
        'line': 'curve',
        'square': 'rectangle',
        'triangle': 'isosceles triangle'
    }
    
    refined_sketch = []
    for element in sketch.split():
        if element.lower() in refinements:
            refined_sketch.append(refinements[element.lower()])
        else:
            refined_sketch.append(element)
    
    return ' '.join(refined_sketch)

def main():
    """
    Main function to demonstrate the refinement of a sketch.
    """
    try:
        # Example rough sketch
        sketch = "dot line square triangle"
        
        # Refine the sketch
        detailed_drawing = refine_sketch(sketch)
        
        print("Original Sketch:", sketch)
        print("Refined Drawing:", detailed_drawing)
    
    except ValueError as e:
        print(f"Error: {e}")

if __name__ == "__main__":
    main()
