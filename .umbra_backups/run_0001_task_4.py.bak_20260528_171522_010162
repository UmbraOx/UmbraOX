import os
import sys
from pathlib import Path

# Configuration options
ENEMY_COLOR = 'red'
PLAYER_POSITION = (0, 0)
ENEMY_POSITION = (5, 5)
MAP_SIZE = (10, 10)
DRY_RUN = False

def print_map(player_pos, enemy_pos):
    for y in range(MAP_SIZE[1]):
        row = []
        for x in range(MAP_SIZE[0]):
            if (x, y) == player_pos:
                row.append('P')
            elif (x, y) == enemy_pos:
                row.append('E')
            else:
                row.append('.')
        print(' '.join(row))

def move_enemy_towards_player(player_pos, enemy_pos):
    px, py = player_pos
    ex, ey = enemy_pos

    # Calculate direction to move
    dx = 1 if px > ex else -1 if px < ex else 0
    dy = 1 if py > ey else -1 if py < ey else 0

    # Move the enemy
    new_enemy_pos = (ex + dx, ey + dy)
    return new_enemy_pos

def main():
    if DRY_RUN:
        print("Dry run mode. No changes will be made.")
    
    print(f"Initial map with player at {PLAYER_POSITION} and enemy at {ENEMY_POSITION}:")
    print_map(PLAYER_POSITION, ENEMY_POSITION)

    # Move the enemy towards the player
    new_enemy_position = move_enemy_towards_player(PLAYER_POSITION, ENEMY_POSITION)
    if not DRY_RUN:
        ENEMY_POSITION = new_enemy_position

    print("\nAfter moving the enemy:")
    print_map(PLAYER_POSITION, new_enemy_position)

if __name__ == "__main__":
    # Parse command-line arguments
    import argparse
    parser = argparse.ArgumentParser(description="Move an enemy towards a player.")
    parser.add_argument('--player-pos', type=str, help='Player position as "x,y"')
    parser.add_argument('--enemy-pos', type=str, help='Enemy position as "x,y"')
    parser.add_argument('--map-size', type=str, help='Map size as "width,height"')
    parser.add_argument('--dry-run', action='store_true', help='Run without making changes')

    args = parser.parse_args()

    # Update configuration from command-line arguments
    if args.player_pos:
        PLAYER_POSITION = tuple(map(int, args.player_pos.split(',')))
    if args.enemy_pos:
        ENEMY_POSITION = tuple(map(int, args.enemy_pos.split(',')))
    if args.map_size:
        MAP_SIZE = tuple(map(int, args.map_size.split(',')))
    if args.dry_run:
        DRY_RUN = True

    main()
