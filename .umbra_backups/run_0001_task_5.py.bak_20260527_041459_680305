import json

def format_headlines_to_json(headlines):
    """
    This function takes a list of headlines and formats them into a JSON structure.
    
    Args:
    headlines (list): A list of headline strings.
    
    Returns:
    str: A JSON string representing the formatted headlines.
    
    Raises:
    TypeError: If the input is not a list.
    ValueError: If any item in the list is not a string.
    """
    if not isinstance(headlines, list):
        raise TypeError("Input must be a list of strings.")
    
    for headline in headlines:
        if not isinstance(headline, str):
            raise ValueError("All items in the list must be strings.")
    
    json_structure = {"headlines": headlines}
    return json.dumps(json_structure, indent=4)

# Example usage
if __name__ == "__main__":
    try:
        headlines = [
            "Python Programming: A Beginner's Guide",
            "Advanced Techniques for Machine Learning",
            "Exploring the World of Quantum Computing"
        ]
        
        formatted_json = format_headlines_to_json(headlines)
        print(formatted_json)
    
    except (TypeError, ValueError) as e:
        print(f"Error: {e}")
