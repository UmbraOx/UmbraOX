import pytest
from unittest.mock import MagicMock, patch
from agent_capability_matrix import AgentCapabilityMatrix

# Mocking the AgentCapabilityMatrix class for demonstration purposes
class AgentCapabilityMatrix:
    def __init__(self):
        self.capabilities = {}

    def update_capability(self, agent_id, capability):
        self.capabilities[agent_id] = capability

    def get_capabilities(self):
        return self.capabilities

    def has_capability(self, agent_id, capability):
        return self.capabilities.get(agent_id) == capability

# Test fixtures
@pytest.fixture
def agent_matrix():
    return AgentCapabilityMatrix()

# Test cases
def test_update_capability_happy_path(agent_matrix):
    agent_id = "agent1"
    capability = "task_processing"
    agent_matrix.update_capability(agent_id, capability)
    assert agent_matrix.capabilities[agent_id] == capability, "Capability should be updated correctly"

def test_get_capabilities_happy_path(agent_matrix):
    agent_id = "agent2"
    capability = "data_analytics"
    agent_matrix.update_capability(agent_id, capability)
    capabilities = agent_matrix.get_capabilities()
    assert capabilities == {agent_id: capability}, "Capabilities dictionary should match the expected output"

def test_has_capability_happy_path(agent_matrix):
    agent_id = "agent3"
    capability = "machine_learning"
    agent_matrix.update_capability(agent_id, capability)
    assert agent_matrix.has_capability(agent_id, capability) is True, "Agent should have the specified capability"

def test_update_capability_edge_case(agent_matrix):
    agent_id = ""
    capability = "task_processing"
    with pytest.raises(ValueError, match="Invalid agent ID"):
        agent_matrix.update_capability(agent_id, capability)

@patch.object(AgentCapabilityMatrix, 'update_capability')
def test_update_capability_dependency(mock_update, agent_matrix):
    mock_update.return_value = None
    agent_id = "agent4"
    capability = "task_processing"
    agent_matrix.update_capability(agent_id, capability)
    mock_update.assert_called_once_with(agent_id, capability)

