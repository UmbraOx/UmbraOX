import pygame
import sys

def main():
    """
    Main function to initialize Pygame and run the game at 60 FPS.
    """
    # Initialize Pygame
    pygame.init()

    # Set up the display
    screen_width, screen_height = 800, 600
    screen = pygame.display.set_mode((screen_width, screen_height))
    pygame.display.set_caption("60 FPS Game")

    # Clock to control frames per second
    clock = pygame.time.Clock()

    # Main game loop
    running = True
    while running:
        # Handle events
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

        # Update game state (e.g., move objects, check collisions)

        # Render the screen
        screen.fill((0, 0, 0))  # Clear the screen with black color
        # Draw your game elements here

        # Update the display
        pygame.display.flip()

        # Cap the frame rate to 60 FPS
        clock.tick(60)

    # Clean up
    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
