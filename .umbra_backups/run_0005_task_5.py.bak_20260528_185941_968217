import os
import sys
from pathlib import Path
import shutil
import subprocess

# Constants for paths (can be overridden by arguments)
SOURCE_DIR = Path('/path/to/source')
DEST_DIR = Path('/path/to/destination')

def process_directory(source, destination, dry_run=False):
    """
    Process the directory from source to destination.
    :param source: Source directory path
    :param destination: Destination directory path
    :param dry_run: If True, perform a dry run without making changes
    """
    summary = {
        'total_files': 0,
        'copied_files': 0,
        'skipped_files': 0,
        'errors': []
    }

    if not source.exists():
        print(f"Error: Source directory {source} does not exist.")
        return summary

    if not destination.exists():
        print(f"Creating destination directory {destination}")
        if not dry_run:
            os.makedirs(destination)

    for item in source.iterdir():
        summary['total_files'] += 1
        rel_path = item.relative_to(source)
        dest_item = destination / rel_path

        try:
            if item.is_file():
                if dry_run:
                    print(f"Dry run: Copying {item} to {dest_item}")
                else:
                    shutil.copy2(item, dest_item)
                    print(f"Copied {item} to {dest_item}")
                summary['copied_files'] += 1
            elif item.is_dir():
                if dry_run:
                    print(f"Dry run: Creating directory {dest_item}")
                else:
                    os.makedirs(dest_item, exist_ok=True)
                    print(f"Created directory {dest_item}")
        except Exception as e:
            summary['errors'].append(str(e))
            print(f"Error processing {item}: {e}")
            summary['skipped_files'] += 1

    return summary

def main():
    if len(sys.argv) < 2:
        print("Usage: python script.py <source_directory> [destination_directory] [--dry-run]")
        sys.exit(1)

    source_dir = Path(sys.argv[1])
    dest_dir = SOURCE_DIR if len(sys.argv) < 3 else Path(sys.argv[2])
    dry_run = '--dry-run' in sys.argv

    print(f"Processing directory from {source_dir} to {dest_dir}")
    summary = process_directory(source_dir, dest_dir, dry_run)

    print("\nSummary:")
    print(f"Total files: {summary['total_files']}")
    print(f"Copied files: {summary['copied_files']}")
    print(f"Skipped files: {summary['skipped_files']}")
    if summary['errors']:
        print("Errors encountered:")
        for error in summary['errors']:
            print(f"- {error}")

if __name__ == "__main__":
    main()
