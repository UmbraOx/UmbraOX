import pandas as pd
import numpy as np

def analyze_data(file_path=None):
    """
    Analyzes a given CSV file or generates sample data for analysis.
    
    Parameters:
    - file_path (str, optional): The path to the CSV file. If None, generates sample data.
    
    Returns:
    - None: Prints analysis results and formatted output.
    """
    
    # Load data from CSV or generate sample data
    if file_path is not None:
        # Read CSV using pandas
        df = pd.read_csv(file_path)
    else:
        # Generate sample data for demonstration
        np.random.seed(0)  # For reproducibility
        data = {
            'A': np.random.randint(1, 100, size=50),
            'B': np.random.randn(50),
            'C': pd.date_range('2023-01-01', periods=50),
            'D': [np.nan] * 25 + list(range(25))
        }
        df = pd.DataFrame(data)
    
    # Handle missing data
    print("Handling missing data...")
    df.dropna(inplace=True)  # Drop rows with any NaN values for simplicity
    
    # Column type detection
    print("\nColumn types:")
    for column, dtype in df.dtypes.items():
        print(f"{column}: {dtype}")
    
    # Basic statistical analysis
    print("\nBasic statistics:")
    stats = df.describe(include='all')
    print(stats)
    
    # Additional insights: Correlation matrix
    if len(df.select_dtypes(include=['number']).columns) > 1:
        print("\nCorrelation Matrix:")
        correlation_matrix = df.corr(numeric_only=True)
        print(correlation_matrix)
    else:
        print("No numeric columns available for correlation analysis.")
    
    # Additional insights: Unique values count
    print("\nUnique values in each column:")
    for column in df.columns:
        unique_count = df[column].nunique()
        print(f"{column}: {unique_count} unique value(s)")

# Example usage:
# analyze_data('your_file.csv')  # Uncomment to use a CSV file
analyze_data()  # Use generated sample data
