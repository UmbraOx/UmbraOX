from flask import Flask, request, jsonify

app = Flask(__name__)

# In-memory data store for demonstration purposes
items = []

class Item:
    def __init__(self, name, description):
        self.name = name
        self.description = description

@app.route('/api/items', methods=['POST'])
def create_item():
    """
    Create a new item.

    Request body should be JSON with 'name' and 'description' fields.
    
    Returns:
        201 Created if the item is created successfully.
        400 Bad Request if the request body is invalid.
    """
    data = request.get_json()

    # Validate request data
    if not data or 'name' not in data or 'description' not in data:
        return jsonify({"error": "Invalid request data"}), 400

    name = data['name']
    description = data['description']

    # Create a new item and add it to the list
    new_item = Item(name, description)
    items.append(new_item)

    # Return the created item with 201 status code
    return jsonify({"id": len(items) - 1, "name": name, "description": description}), 201

if __name__ == '__main__':
    app.run(debug=True)
