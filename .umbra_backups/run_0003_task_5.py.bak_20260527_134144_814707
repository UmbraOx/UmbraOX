import os
import shutil
import logging

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

def backup_current_version(current_dir, backup_dir):
    """
    Backup the current version of the project.
    
    Args:
        current_dir (str): The directory containing the current version of the project.
        backup_dir (str): The directory where the backup should be stored.
    """
    try:
        if os.path.exists(backup_dir):
            logging.warning(f"Backup directory '{backup_dir}' already exists. Overwriting.")
        shutil.copytree(current_dir, backup_dir)
        logging.info(f"Successfully backed up current version to {backup_dir}")
    except Exception as e:
        logging.error(f"Failed to backup current version: {e}")
        raise

def upgrade_project(current_dir, new_version_dir):
    """
    Upgrade the project by replacing the current version with the new version.
    
    Args:
        current_dir (str): The directory containing the current version of the project.
        new_version_dir (str): The directory containing the new version of the project.
    """
    try:
        # Remove the current version
        shutil.rmtree(current_dir)
        logging.info(f"Removed current version from {current_dir}")
        
        # Move the new version to the current location
        shutil.move(new_version_dir, current_dir)
        logging.info(f"Successfully upgraded project to new version at {current_dir}")
    except Exception as e:
        logging.error(f"Failed to upgrade project: {e}")
        raise

def main():
    """
    Main function to execute the upgrade process.
    """
    current_project_dir = '/path/to/current/project'
    backup_directory = '/path/to/backup/directory'
    new_version_directory = '/path/to/new/version'

    try:
        # Step 1: Backup the current version
        backup_current_version(current_project_dir, backup_directory)
        
        # Step 2: Upgrade the project to the new version
        upgrade_project(current_project_dir, new_version_directory)
        
        logging.info("Upgrade process completed successfully.")
    except Exception as e:
        logging.error(f"An error occurred during the upgrade process: {e}")

if __name__ == "__main__":
    main()
