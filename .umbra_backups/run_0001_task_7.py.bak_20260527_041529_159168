import pandas as pd

class DatabaseManager:
    def __init__(self, data):
        """
        Initialize the DatabaseManager with a dataset.
        
        Parameters:
            data (pd.DataFrame): The dataset to manage.
        """
        self.data = data.copy()  # Use a copy of the data to avoid modifying the original DataFrame
        
    def delete_record(self, index):
        """
        Delete a record from the database based on its index.
        
        Parameters:
            index (int): The index of the record to delete.
            
        Returns:
            None
        """
        if not isinstance(index, int):
            raise ValueError("Index must be an integer.")
        
        # Check if the index exists in the DataFrame
        if index < 0 or index >= len(self.data):
            print(f"Error: Index {index} is out of range. No record deleted.")
            return
        
        # Print the record to be deleted for confirmation
        record_to_delete = self.data.iloc[index]
        print("Deleting record:")
        print(record_to_delete)
        
        # Drop the record from the DataFrame
        self.data.drop(index, inplace=True)
        
        # Reset the index of the DataFrame to maintain continuous indexing
        self.data.reset_index(drop=True, inplace=True)
        
        # Print a success message
        print(f"Record at index {index} has been deleted successfully.")
    
    def describe_data(self):
        """
        Provide a summary description of the dataset.
        
        Returns:
            pd.DataFrame: A DataFrame describing the dataset's statistics and types.
        """
        return self.data.describe(include='all')

# Example usage:
if __name__ == "__main__":
    # Sample data
    data = {
        'Name': ['Alice', 'Bob', 'Charlie'],
        'Age': [25, 30, 35],
        'Salary': [50000.0, 60000.0, 70000.0]
    }
    
    # Create an instance of DatabaseManager
    db_manager = DatabaseManager(pd.DataFrame(data))
    
    # Print initial data description
    print("Initial Data Description:")
    print(db_manager.describe_data())
    
    # Delete a record
    db_manager.delete_record(1)
    
    # Print updated data description
    print("\nUpdated Data Description after deletion:")
    print(db_manager.describe_data())
