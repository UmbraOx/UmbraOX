# Import necessary modules
import json

# Define global variables for the conversation history
conversation_history = []

def load_conversation():
    """
    Load the conversation history from a JSON file if it exists.
    """
    try:
        with open('conversation_history.json', 'r') as file:
            global conversation_history
            conversation_history = json.load(file)
    except FileNotFoundError:
        print("No existing conversation history found.")
    except json.JSONDecodeError:
        print("Failed to decode the conversation history. Starting a new session.")

def save_conversation():
    """
    Save the current conversation history to a JSON file.
    """
    try:
        with open('conversation_history.json', 'w') as file:
            json.dump(conversation_history, file)
    except IOError:
        print("Failed to save the conversation history.")

if __name__ == "__main__":
    load_conversation()
    # Example of adding a new message to the conversation history
    conversation_history.append({"role": "user", "content": "Hello!"})
    conversation_history.append({"role": "assistant", "content": "Hi there!"})
    save_conversation()
