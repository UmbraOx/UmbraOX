def test_move_files_permission_error():
    # Arrange
    source_folder = '/source'
    target_folders = {
        'txt': '/target/txt',
        'jpg': '/target/jpg'
    }
    files_to_move = [
        {'name': 'document.txt', 'extension': 'txt'}
    ]
    
    # Mock the move function from shutil to raise PermissionError
    with patch('shutil.move') as mock_shutil_move:
        mock_shutil_move.side_effect = PermissionError("Permission denied")
        summary = move_files_to_folders(source_folder, target_folders, files_to_move)
    
    # Assert
    assert len(summary.moved_files) == 0
    assert 'document.txt' not in summary.moved_files
    mock_shutil_move.assert_called_once_with(os.path.join(source_folder, 'document.txt'), os.path.join(target_folders['txt'], 'document.txt'))
