import os
from unittest.mock import patch, mock_open
import pytest
from shutil import move as shutil_move

# Let's assume the module being tested is named file_mover.py
from file_mover import move_files_to_folders, FileMoveSummary

def test_move_files_happy_path():
    # Arrange
    source_folder = '/source'
    target_folders = {
        'txt': '/target/txt',
        'jpg': '/target/jpg'
    }
    files_to_move = [
        {'name': 'document.txt', 'extension': 'txt'},
        {'name': 'photo.jpg', 'extension': 'jpg'}
    ]
    
    # Mock the move function from shutil
    with patch('shutil.move') as mock_shutil_move:
        summary = move_files_to_folders(source_folder, target_folders, files_to_move)
    
    # Assert
    assert len(summary.moved_files) == 2
    assert 'document.txt' in summary.moved_files
    assert 'photo.jpg' in summary.moved_files
    mock_shutil_move.assert_any_call(os.path.join(source_folder, 'document.txt'), os.path.join(target_folders['txt'], 'document.txt'))
    mock_shutil_move.assert_any_call(os.path.join(source_folder, 'photo.jpg'), os.path.join(target_folders['jpg'], 'photo.jpg'))

def test_move_files_no_target_folder():
    # Arrange
    source_folder = '/source'
    target_folders = {
        'txt': '/target/txt',
        'jpg': '/target/jpg'
    }
    files_to_move = [
        {'name': 'document.txt', 'extension': 'txt'},
        {'name': 'photo.jpg', 'extension': 'gif'}
    ]
    
    # Mock the move function from shutil
    with patch('shutil.move') as mock_shutil_move:
        summary = move_files_to_folders(source_folder, target_folders, files_to_move)
    
    # Assert
    assert len(summary.moved_files) == 1
    assert 'document.txt' in summary.moved_files
    assert 'photo.jpg' not in summary.moved_files
    mock_shutil_move.assert_called_once_with(os.path.join(source_folder, 'document.txt'), os.path.join(target_folders['txt'], 'document.txt'))

