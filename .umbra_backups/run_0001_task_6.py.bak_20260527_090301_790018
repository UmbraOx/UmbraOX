import pygame
import sys

# Initialize Pygame
pygame.init()

# Screen dimensions
SCREEN_WIDTH = 800
SCREEN_HEIGHT = 600

# Colors
WHITE = (255, 255, 255)
RED = (255, 0, 0)

# Player settings
PLAYER_SIZE = 50
PLAYER_COLOR = BLUE = (0, 0, 255)
PLAYER_SPEED = 5

# Health settings
MAX_HEALTH = 3
HEALTH_FONT = pygame.font.Font(None, 36)

# Create the screen
screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
pygame.display.set_caption("Player Respawning Example")

class Player:
    def __init__(self):
        self.size = PLAYER_SIZE
        self.color = PLAYER_COLOR
        self.x = SCREEN_WIDTH // 2 - self.size // 2
        self.y = SCREEN_HEIGHT // 2 - self.size // 2
        self.speed = PLAYER_SPEED
        self.health = MAX_HEALTH

    def draw(self, screen):
        pygame.draw.rect(screen, self.color, (self.x, self.y, self.size, self.size))

    def respawn(self):
        self.x = SCREEN_WIDTH // 2 - self.size // 2
        self.y = SCREEN_HEIGHT // 2 - self.size // 2
        self.health -= 1

def main():
    player = Player()
    clock = pygame.time.Clock()

    while True:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                pygame.quit()
                sys.exit()

        # Check for collisions (for demonstration, we'll simulate a collision every second)
        keys = pygame.key.get_pressed()
        if keys[pygame.K_SPACE]:
            player.respawn()

        # Clear the screen
        screen.fill(WHITE)

        # Draw the player
        player.draw(screen)

        # Display health
        health_text = HEALTH_FONT.render(f"Health: {player.health}", True, RED)
        screen.blit(health_text, (10, 10))

        # Update the display
        pygame.display.flip()

        # Cap the frame rate
        clock.tick(60)

if __name__ == "__main__":
    main()
