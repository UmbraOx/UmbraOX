import pygame
import sys

def initialize_pygame():
    """
    Initialize the Pygame environment and create the main game window.
    """
    try:
        # Initialize Pygame
        pygame.init()
        
        # Set up the display
        screen_width = 800
        screen_height = 600
        screen = pygame.display.set_mode((screen_width, screen_height))
        pygame.display.set_caption("Pygame Main Window")
        
        # Main game loop
        running = True
        while running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False
            
            # Fill the screen with a color (e.g., white)
            screen.fill((255, 255, 255))
            
            # Update the display
            pygame.display.flip()
        
        # Quit Pygame
        pygame.quit()
        sys.exit(0)
    
    except pygame.error as e:
        print(f"Pygame error: {e}")
    except Exception as e:
        print(f"An unexpected error occurred: {e}")

if __name__ == "__main__":
    initialize_pygame()
