import sqlite3
import pandas as pd
from statistics import mean, stdev

class DatabaseManager:
    def __init__(self, db_path):
        """
        Initializes a new instance of DatabaseManager and establishes a connection to the SQLite database.
        
        Parameters:
        - db_path (str): The file path to the SQLite database.
        """
        self.connection = sqlite3.connect(db_path)
        print("Database connection established.")

    def fetch_data(self, query):
        """
        Fetches data from the database using a SQL query and returns it as a pandas DataFrame.
        
        Parameters:
        - query (str): The SQL query to execute.
        
        Returns:
        - pd.DataFrame: A DataFrame containing the results of the query.
        """
        try:
            df = pd.read_sql_query(query, self.connection)
            print("Data fetched successfully.")
            return df
        except Exception as e:
            print(f"An error occurred while fetching data: {e}")
            return None

    def analyze_data(self, df):
        """
        Analyzes the DataFrame by performing standard statistical methods and handling missing data.
        
        Parameters:
        - df (pd.DataFrame): The DataFrame to analyze.
        
        Returns:
        - dict: A dictionary containing analysis results including mean, standard deviation, and column types.
        """
        if df is None or df.empty:
            print("No data to analyze.")
            return {}

        # Handling missing data
        df_cleaned = df.dropna()
        print(f"Missing data handled. Original rows: {len(df)}, Cleaned rows: {len(df_cleaned)}")

        # Column type detection
        column_types = df.dtypes.apply(lambda x: x.name).to_dict()
        print("Column types detected.")

        # Basic statistical analysis
        stats = {}
        for column in df_cleaned.columns:
            if pd.api.types.is_numeric_dtype(df_cleaned[column]):
                col_mean = mean(df_cleaned[column])
                col_stdev = stdev(df_cleaned[column]) if len(df_cleaned[column]) > 1 else None
                stats[column] = {'mean': col_mean, 'std_deviation': col_stdev}

        print("Basic statistical analysis completed.")
        return {
            'column_types': column_types,
            'statistics': stats
        }

    def close_connection(self):
        """
        Closes the database connection.
        """
        if self.connection:
            self.connection.close()
            print("Database connection closed.")

