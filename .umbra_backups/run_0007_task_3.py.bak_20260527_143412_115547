import os
from pathlib import Path
import shutil
import subprocess
import sys

# Configuration constants
BASE_PATH = Path(r'C:\Umbra\gui')
DRY_RUN = False  # Set to True for dry run mode

def main():
    if len(sys.argv) > 1:
        global DRY_RUN
        if sys.argv[1].lower() == '--dry-run':
            DRY_RUN = True
            print("Dry run mode enabled. No changes will be made.")

    try:
        process_files_and_directories(BASE_PATH)
    except Exception as e:
        print(f"An error occurred: {e}")

def process_files_and_directories(path):
    if not path.exists():
        raise FileNotFoundError(f"The path {path} does not exist.")
    
    if not path.is_dir():
        raise NotADirectoryError(f"The path {path} is not a directory.")

    for item in path.iterdir():
        if item.is_file():
            process_file(item)
        elif item.is_dir():
            process_directory(item)

def process_file(file_path):
    print(f"Processing file: {file_path}")
    if DRY_RUN:
        print("Dry run: Skipping file processing.")
        return

    # Example operation: Copy the file to a backup directory
    backup_dir = BASE_PATH / 'backup'
    backup_dir.mkdir(parents=True, exist_ok=True)
    backup_file_path = backup_dir / file_path.name
    shutil.copy(file_path, backup_file_path)
    print(f"Copied {file_path} to {backup_file_path}")

def process_directory(dir_path):
    print(f"Processing directory: {dir_path}")
    if DRY_RUN:
        print("Dry run: Skipping directory processing.")
        return

    # Example operation: Rename the directory
    new_dir_name = f"{dir_path.name}_processed"
    new_dir_path = dir_path.parent / new_dir_name
    os.rename(dir_path, new_dir_path)
    print(f"Renamed {dir_path} to {new_dir_path}")

if __name__ == "__main__":
    main()
