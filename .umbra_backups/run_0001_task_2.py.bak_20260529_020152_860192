import os
import pathlib
import subprocess
import urllib.request
import json

# Configuration
OLLAMA_URL = "http://localhost:11434/analyze"
INPUT_FILE_PATH = "path/to/your/script.py"  # Make this configurable
DRY_RUN = False  # Set to True for a dry run

def read_file(file_path):
    """Read the content of a file."""
    try:
        with open(file_path, 'r') as file:
            return file.read()
    except FileNotFoundError:
        print(f"Error: The file {file_path} was not found.")
        return None
    except IOError as e:
        print(f"Error: An I/O error occurred while reading the file {file_path}. {e}")
        return None

def send_to_ollama(file_content):
    """Send the file content to Ollama for analysis."""
    try:
        data = json.dumps({"code": file_content}).encode('utf-8')
        req = urllib.request.Request(OLLAMA_URL, method='POST', data=data,
                                     headers={'Content-Type': 'application/json'})
        
        with urllib.request.urlopen(req) as response:
            return response.read().decode('utf-8')
    except urllib.error.URLError as e:
        print(f"Error: Unable to reach Ollama server at {OLLAMA_URL}. {e}")
        return None
    except Exception as e:
        print(f"Error: An unexpected error occurred while sending data to Ollama. {e}")
        return None

def main():
    # Print progress output
    print("Reading the Python file...")
    
    # Read the file content
    file_content = read_file(INPUT_FILE_PATH)
    if file_content is None:
        return
    
    if DRY_RUN:
        print("Dry run: Not sending data to Ollama.")
        print(f"Content of {INPUT_FILE_PATH}:\n{file_content[:100]}...")  # Print first 100 characters
        return
    
    # Send the file content to Ollama for analysis
    print("Sending the Python file to Ollama for analysis...")
    response = send_to_ollama(file_content)
    if response is None:
        return
    
    # Print the analysis result
    print("Analysis result from Ollama:")
    print(response)

if __name__ == "__main__":
    main()
