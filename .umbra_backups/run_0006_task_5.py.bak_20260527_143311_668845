"""
This script creates the frontend components of a dashboard using HTML, CSS, and JavaScript (React).
It generates the necessary files for a basic web application structure.
"""

import os

def create_html():
    """Create an index.html file with basic structure."""
    html_content = """
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div id="root"></div>
    <script src="bundle.js"></script>
</body>
</html>
"""
    try:
        with open('index.html', 'w') as file:
            file.write(html_content)
    except IOError as e:
        print(f"Error writing HTML file: {e}")

def create_css():
    """Create a styles.css file with basic styling."""
    css_content = """
body {
    font-family: Arial, sans-serif;
    margin: 0;
    padding: 0;
    display: flex;
    justify-content: center;
    align-items: center;
    height: 100vh;
    background-color: #f0f0f0;
}

#root {
    background-color: white;
    border-radius: 8px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    padding: 20px;
    width: 300px;
    text-align: center;
}
"""
    try:
        with open('styles.css', 'w') as file:
            file.write(css_content)
    except IOError as e:
        print(f"Error writing CSS file: {e}")

def create_js():
    """Create a src/index.js file for React app entry point."""
    js_content = """
import React from 'react';
import ReactDOM from 'react-dom';

const Dashboard = () => {
    return (
        <div>
            <h1>Welcome to the Dashboard</h1>
            <p>This is a simple dashboard built with React.</p>
        </div>
    );
};

ReactDOM.render(<Dashboard />, document.getElementById('root'));
"""
    try:
        os.makedirs('src', exist_ok=True)
        with open('src/index.js', 'w') as file:
            file.write(js_content)
    except IOError as e:
        print(f"Error writing JavaScript file: {e}")

if __name__ == '__main__':
    create_html()
    create_css()
    create_js()

    print("Frontend components created successfully.")
