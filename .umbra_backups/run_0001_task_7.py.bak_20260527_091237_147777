import time

def display_game_over():
    """
    Display the Game Over screen.
    """
    print("\n" * 10)  # Clear the screen
    print("**********************")
    print("*      GAME OVER     *")
    print("**********************")
    print("\nPress Enter to exit.")
    input()  # Wait for user input to exit

def main_game_loop():
    """
    Main game loop that decreases player health until it reaches 0.
    """
    player_health = 100
    while player_health > 0:
        print(f"Player Health: {player_health}")
        time.sleep(1)  # Simulate some game action
        player_health -= 10  # Decrease health
        if player_health <= 0:
            display_game_over()
            break

if __name__ == "__main__":
    try:
        main_game_loop()
    except KeyboardInterrupt:
        print("\nGame interrupted by user.")
