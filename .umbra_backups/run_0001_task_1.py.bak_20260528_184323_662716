"""
Setup for Pygame Environment and Create a Window

This script initializes the Pygame library and creates a simple window with a title.
It handles basic errors such as Pygame not being installed or issues initializing the display.
"""

import pygame
import sys

def main():
    """
    Main function to initialize Pygame and create a window.
    """
    # Initialize Pygame
    try:
        pygame.init()
    except pygame.error as e:
        print(f"Failed to initialize Pygame: {e}")
        sys.exit(1)

    # Set up the display
    width, height = 800, 600
    title = "Pygame Window"
    
    try:
        screen = pygame.display.set_mode((width, height))
    except pygame.error as e:
        print(f"Failed to create window: {e}")
        pygame.quit()
        sys.exit(1)

    # Set the window title
    pygame.display.set_caption(title)

    # Main loop
    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False

    # Quit Pygame
    pygame.quit()

if __name__ == "__main__":
    main()
