"""
This script uses matplotlib to create a simple representation of an ice cream cone.
"""

import matplotlib.pyplot as plt
import numpy as np

def draw_ice_cream_cone():
    """
    Draws a simple representation of an ice cream cone using matplotlib.
    """
    try:
        # Create a new figure and axis
        fig, ax = plt.subplots()

        # Draw the cone
        x_cone = [0, 1, 0.5]
        y_cone = [0, 0, 1]
        ax.fill(x_cone, y_cone, 'brown')

        # Draw the ice cream
        x_ice_cream = np.linspace(0.2, 0.8, 100)
        y_ice_cream = np.sqrt(0.6**2 - (x_ice_cream - 0.5)**2) + 1
        ax.fill(x_ice_cream, y_ice_cream, 'orange')

        # Set aspect ratio to be equal so the cone looks correct
        ax.set_aspect('equal', adjustable='box')

        # Remove axes for a cleaner look
        ax.axis('off')

        # Display the plot
        plt.show()

    except Exception as e:
        print(f"An error occurred: {e}")

if __name__ == "__main__":
    draw_ice_cream_cone()
