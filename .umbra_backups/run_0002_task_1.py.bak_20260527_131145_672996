#!/usr/bin/env python3

import os
from pathlib import Path
import sys
import argparse
import logging

# Configure logging
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(message)s')

# Default paths (can be overridden via command line arguments)
DEFAULT_INPUT_DIR = 'input'
DEFAULT_OUTPUT_DIR = 'output'

def create_directories(input_dir, output_dir):
    """
    Create input and output directories if they do not exist.
    """
    try:
        Path(input_dir).mkdir(parents=True, exist_ok=True)
        Path(output_dir).mkdir(parents=True, exist_ok=True)
        logging.info(f"Directories created: {input_dir}, {output_dir}")
    except Exception as e:
        logging.error(f"Error creating directories: {e}")

def main():
    # Parse command line arguments
    parser = argparse.ArgumentParser(description='Agent Capability Matrix Tool')
    parser.add_argument('--input-dir', default=DEFAULT_INPUT_DIR, help='Input directory path (default: input)')
    parser.add_argument('--output-dir', default=DEFAULT_OUTPUT_DIR, help='Output directory path (default: output)')
    parser.add_argument('--dry-run', action='store_true', help='Perform a dry run without making changes')
    
    args = parser.parse_args()

    # Log the configuration
    logging.info(f"Using input directory: {args.input_dir}")
    logging.info(f"Using output directory: {args.output_dir}")

    if args.dry_run:
        logging.warning("Dry-run mode enabled. No changes will be made.")

    # Create directories if they don't exist
    create_directories(args.input_dir, args.output_dir)

if __name__ == "__main__":
    main()
