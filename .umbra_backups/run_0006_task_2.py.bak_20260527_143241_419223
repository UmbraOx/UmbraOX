from flask import Flask, request, jsonify
from marshmallow import Schema, fields, validate, ValidationError

app = Flask(__name__)

# Example model schema using Marshmallow for validation
class ItemSchema(Schema):
    name = fields.Str(required=True, validate=validate.Length(min=1))
    price = fields.Float(required=True, validate=validate.Range(min=0))

def validate_input(schema, input_data):
    try:
        return schema.load(input_data)
    except ValidationError as err:
        return jsonify(err.messages), 400

@app.route('/items', methods=['POST'])
def create_item():
    """
    Create a new item.

    **Request Body:**
    - `name` (string): Name of the item, required.
    - `price` (float): Price of the item, required and must be non-negative.

    Returns:
        201 Created: JSON response with created item details.
        400 Bad Request: Validation errors.
    """
    data = request.get_json()
    validation_result = validate_input(ItemSchema(), data)
    
    if isinstance(validation_result, tuple):
        return validation_result
    
    # Simulate item creation
    new_item = {
        'id': len(items) + 1,
        **validation_result
    }
    items.append(new_item)
    return jsonify(new_item), 201

@app.errorhandler(404)
def not_found(error):
    """
    Handle 404 Not Found errors.

    Returns:
        404 Not Found: JSON response with error message.
    """
    return jsonify({'error': 'Not found'}), 404

@app.errorhandler(500)
def internal_error(error):
    """
    Handle 500 Internal Server Error.

    Returns:
        500 Internal Server Error: JSON response with error message.
    """
    app.logger.error(error)
    return jsonify({'error': 'Internal server error'}), 500

# In-memory storage for demonstration purposes
items = []

if __name__ == '__main__':
    app.run(debug=True)
