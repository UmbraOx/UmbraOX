from typing import Dict, List, Optional

class AgentCapabilityMatrix:
    """
    This class represents an agent capability matrix which holds various attributes
    related to an agent's capabilities in different domains.
    
    Attributes:
        agent_id (str): A unique identifier for the agent.
        domain_capabilities (Dict[str, float]): A dictionary mapping domain names to 
            the agent's proficiency level in that domain, represented as a float between 0 and 1.
        supported_tasks (List[str]): A list of tasks that the agent can perform.
    """
    
    def __init__(self, agent_id: str, domain_capabilities: Dict[str, float], supported_tasks: List[str]):
        """
        Initializes an instance of AgentCapabilityMatrix.
        
        Args:
            agent_id (str): The unique identifier for the agent.
            domain_capabilities (Dict[str, float]): A dictionary with domain names as keys 
                and proficiency levels as values.
            supported_tasks (List[str]): A list of tasks the agent can perform.
        
        Raises:
            ValueError: If any domain capability is not between 0 and 1.
        """
        self.agent_id = agent_id
        self.domain_capabilities = {domain: cap for domain, cap in domain_capabilities.items() if 0 <= cap <= 1}
        if len(self.domain_capabilities) != len(domain_capabilities):
            raise ValueError("Domain capabilities must be a float between 0 and 1.")
        
        self.supported_tasks = supported_tasks
    
    def get_agent_id(self) -> str:
        """
        Returns the agent's unique identifier.
        
        Returns:
            str: The agent ID.
        """
        return self.agent_id
    
    def get_domain_capabilities(self) -> Dict[str, float]:
        """
        Returns the domain capabilities of the agent.
        
        Returns:
            Dict[str, float]: A dictionary mapping domain names to proficiency levels.
        """
        return self.domain_capabilities
    
    def get_supported_tasks(self) -> List[str]:
        """
        Returns the list of tasks supported by the agent.
        
        Returns:
            List[str]: The list of supported tasks.
        """
        return self.supported_tasks
    
    def update_capability(self, domain: str, capability: float):
        """
        Updates the capability level for a specific domain.
        
        Args:
            domain (str): The domain to update.
            capability (float): The new capability level.
            
        Raises:
            ValueError: If the capability is not between 0 and 1.
        """
        if not (0 <= capability <= 1):
            raise ValueError("Capability must be a float between 0 and 1.")
        self.domain_capabilities[domain] = capability
    
    def to_dict(self) -> Dict:
        """
        Converts the AgentCapabilityMatrix object into a dictionary.
        
        Returns:
            Dict: A dictionary representation of the agent's capabilities.
        """
        return {
            "agent_id": self.agent_id,
            "domain_capabilities": self.domain_capabilities,
            "supported_tasks": self.supported_tasks
        }
