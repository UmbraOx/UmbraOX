from typing import Optional, Dict, List

class StockImageManager:
    """
    A class to manage high-quality stock images or models.
    
    This class provides methods to fetch, store, and access stock images or models.
    It includes error handling for invalid operations.
    """

    def __init__(self):
        """
        Initialize the StockImageManager with an empty dictionary to store images.
        """
        self.images: Dict[str, str] = {}

    def add_image(self, image_id: str, image_url: str) -> None:
        """
        Add a new stock image or model to the manager.

        :param image_id: Unique identifier for the image.
        :param image_url: URL where the high-quality image is located.
        :raises ValueError: If the image ID already exists in the manager.
        """
        if image_id in self.images:
            raise ValueError(f"Image with ID '{image_id}' already exists.")
        self.images[image_id] = image_url

    def get_image(self, image_id: str) -> Optional[str]:
        """
        Retrieve a stock image or model by its ID.

        :param image_id: Unique identifier for the image.
        :return: The URL of the image if found, otherwise None.
        """
        return self.images.get(image_id)

    def remove_image(self, image_id: str) -> None:
        """
        Remove a stock image or model from the manager by its ID.

        :param image_id: Unique identifier for the image.
        :raises KeyError: If the image ID does not exist in the manager.
        """
        if image_id not in self.images:
            raise KeyError(f"Image with ID '{image_id}' does not exist.")
        del self.images[image_id]

    def list_images(self) -> List[str]:
        """
        List all available stock images or models.

        :return: A list of image IDs.
        """
        return list(self.images.keys())

    def to_dict(self) -> Dict[str, str]:
        """
        Convert the current state of the manager to a dictionary.

        :return: A dictionary with image IDs as keys and URLs as values.
        """
        return self.images

# Example usage
if __name__ == "__main__":
    manager = StockImageManager()
    try:
        manager.add_image("img001", "https://example.com/image001.jpg")
        manager.add_image("img002", "https://example.com/image002.jpg")
        print(manager.get_image("img001"))  # Output: https://example.com/image001.jpg
        print(manager.list_images())       # Output: ['img001', 'img002']
        manager.remove_image("img001")
        print(manager.list_images())       # Output: ['img002']
    except Exception as e:
        print(f"An error occurred: {e}")
