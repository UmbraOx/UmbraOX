import requests

def get_umbra_version_and_capabilities():
    """
    Fetches the current version and capabilities of Umbra.
    
    Returns:
        dict: A dictionary containing the version and capabilities of Umbra.
    """
    try:
        # Assuming there is an API endpoint to fetch the version and capabilities
        response = requests.get("https://api.umbra.com/info")
        response.raise_for_status()  # Raise an error for bad responses
        
        data = response.json()
        
        # Extracting version and capabilities from the response
        version = data.get('version', 'Unknown')
        capabilities = data.get('capabilities', [])
        
        return {
            'version': version,
            'capabilities': capabilities
        }
    
    except requests.exceptions.RequestException as e:
        print(f"An error occurred while fetching Umbra information: {e}")
        return None

if __name__ == "__main__":
    info = get_umbra_version_and_capabilities()
    if info:
        print(f"Umbra Version: {info['version']}")
        print("Capabilities:")
        for capability in info['capabilities']:
            print(f"- {capability}")
