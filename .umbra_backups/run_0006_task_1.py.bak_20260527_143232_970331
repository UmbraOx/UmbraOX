# Import necessary libraries
import dash
from dash import dcc, html
from dash.dependencies import Input, Output
import plotly.express as px
import pandas as pd

# Initialize the Dash app
app = dash.Dash(__name__)

# Sample data
data = {
    'Category': ['A', 'B', 'C', 'A', 'B', 'C'],
    'Value': [10, 20, 30, 40, 50, 60],
    'Time': pd.date_range(start='1/1/2023', periods=6, freq='D')
}

df = pd.DataFrame(data)

# Define the layout of the app
app.layout = html.Div([
    html.H1("Sample Dashboard"),
    
    # Dropdown for filtering data
    dcc.Dropdown(
        id='category-dropdown',
        options=[{'label': i, 'value': i} for i in df['Category'].unique()],
        value=df['Category'].unique()[0],
        multi=False
    ),
    
    # Line Chart
    html.Div([
        dcc.Graph(id='line-chart')
    ]),
    
    # Bar Chart
    html.Div([
        dcc.Graph(id='bar-chart')
    ])
])

# Callback to update the line chart based on dropdown selection
@app.callback(
    Output('line-chart', 'figure'),
    [Input('category-dropdown', 'value')]
)
def update_line_chart(selected_category):
    filtered_df = df[df['Category'] == selected_category]
    fig = px.line(filtered_df, x='Time', y='Value', title=f'Line Chart for Category {selected_category}')
    return fig

# Callback to update the bar chart based on dropdown selection
@app.callback(
    Output('bar-chart', 'figure'),
    [Input('category-dropdown', 'value')]
)
def update_bar_chart(selected_category):
    filtered_df = df[df['Category'] == selected_category]
    fig = px.bar(filtered_df, x='Time', y='Value', title=f'Bar Chart for Category {selected_category}')
    return fig

# Run the app
if __name__ == '__main__':
    app.run_server(debug=True)
