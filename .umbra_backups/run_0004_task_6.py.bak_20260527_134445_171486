import os

def update_readme(file_path, new_content):
    """
    Update the specified README file with new content.
    
    Parameters:
    - file_path: str, the path to the README file.
    - new_content: str, the new content to write into the README file.
    
    Returns:
    - None
    
    Raises:
    - FileNotFoundError: If the specified file does not exist.
    - PermissionError: If the user does not have permission to write to the file.
    """
    # Check if the file exists
    if not os.path.exists(file_path):
        raise FileNotFoundError(f"The file {file_path} does not exist.")
    
    try:
        # Write new content to the README file
        with open(file_path, 'w', encoding='utf-8') as file:
            file.write(new_content)
        print(f"README file at {file_path} has been successfully updated.")
    except PermissionError:
        raise PermissionError(f"You do not have permission to write to {file_path}.")
    except Exception as e:
        raise Exception(f"An unexpected error occurred: {e}")

