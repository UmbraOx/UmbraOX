# Import necessary modules
from flask import Flask, jsonify, request
from unittest.mock import MagicMock, patch

app = Flask(__name__)

# Mock database
class Database:
    def __init__(self):
        self.items = {
            1: {"id": 1, "name": "Item 1"},
            2: {"id": 2, "name": "Item 2"}
        }

    def get_item_by_id(self, item_id):
        return self.items.get(item_id)

# Route to get an item by ID
@app.route('/api/items/<int:item_id>', methods=['GET'])
def get_item(item_id):
    db = Database()
    item = db.get_item_by_id(item_id)
    if item:
        return jsonify(item), 200
    else:
        return jsonify({"error": "Item not found"}), 404

# Import the module being tested
from app import app, get_item

# Fixtures for test setup
@pytest.fixture
def client():
    app.config['TESTING'] = True
    with app.test_client() as client:
        yield client

# Test the main happy path
def test_get_item_happy_path(client):
    # Mock the database to return an item
    mock_db = MagicMock()
    mock_db.get_item_by_id.return_value = {"id": 1, "name": "Item 1"}
    
    with patch('app.Database', return_value=mock_db):
        response = client.get('/api/items/1')
    
    assert response.status_code == 200
    assert response.json == {"id": 1, "name": "Item 1"}, "Response JSON does not match expected item"

# Test an error/edge case (item not found)
def test_get_item_not_found(client):
    # Mock the database to return None
    mock_db = MagicMock()
    mock_db.get_item_by_id.return_value = None
    
    with patch('app.Database', return_value=mock_db):
        response = client.get('/api/items/3')
    
    assert response.status_code == 404
    assert response.json == {"error": "Item not found"}, "Response JSON does not match expected error message"
