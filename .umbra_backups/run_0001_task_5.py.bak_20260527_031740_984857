import json

def format_headlines_to_json(headlines):
    """
    Formats a list of headlines into a JSON structure.

    Parameters:
    headlines (list): A list of headline strings.

    Returns:
    str: A JSON string representing the formatted headlines.
    
    Raises:
    TypeError: If the input is not a list or if any element in the list is not a string.
    """
    # Validate input
    if not isinstance(headlines, list):
        raise TypeError("Input must be a list of strings.")
    for headline in headlines:
        if not isinstance(headline, str):
            raise TypeError("All elements in the list must be strings.")
    
    # Create JSON structure
    formatted_json = {
        "headlines": headlines
    }
    
    # Convert to JSON string
    try:
        json_string = json.dumps(formatted_json, indent=4)
    except (TypeError, OverflowError) as e:
        raise ValueError("Failed to convert to JSON.") from e
    
    return json_string

# Example usage
if __name__ == "__main__":
    headlines = [
        "Top News Story of the Day",
        "Breaking: Major Event Happens Now",
        "In Depth Analysis on Current Issue"
    ]
    
    try:
        formatted_json = format_headlines_to_json(headlines)
        print(formatted_json)
    except Exception as e:
        print(f"An error occurred: {e}")
