import pytest
from unittest.mock import patch

# Import the module being tested
from my_module import MyClass, some_function

# Happy path test for a method in MyClass
def test_my_class_method_happy_path():
    obj = MyClass()
    result = obj.my_method(10)
    assert result == 20, "Expected result to be double the input"

# Edge case test for a function
def test_some_function_edge_case():
    with pytest.raises(ValueError):
        some_function(-1)

# Test with mocking an external dependency
@patch('my_module.ExternalDependency.some_method')
def test_my_class_with_mock(mock_dependency):
    mock_dependency.return_value = 42
    obj = MyClass()
    result = obj.method_that_uses_external_dependency()
    assert result == 84, "Expected result to be double the mocked value"
