import pygame

class Player:
    def __init__(self, x, y):
        self.x = x
        self.y = y
        self.health = 100

    def take_damage(self, amount):
        if amount < 0:
            raise ValueError("Damage amount must be non-negative")
        self.health -= amount
        if self.health < 0:
            self.health = 0

class Game:
    def __init__(self):
        pygame.init()
        self.screen = pygame.display.set_mode((800, 600))
        pygame.display.set_caption("Health Points Example")
        self.clock = pygame.time.Clock()
        self.player = Player(400, 300)

    def run(self):
        running = True
        while running:
            for event in pygame.event.get():
                if event.type == pygame.QUIT:
                    running = False

            keys = pygame.key.get_pressed()
            if keys[pygame.K_LEFT]:
                self.player.x -= 5
            if keys[pygame.K_RIGHT]:
                self.player.x += 5
            if keys[pygame.K_UP]:
                self.player.y -= 5
            if keys[pygame.K_DOWN]:
                self.player.y += 5

            self.screen.fill((0, 0, 0))
            self.display_health()
            pygame.draw.circle(self.screen, (255, 255, 0), (self.player.x, self.player.y), 20)
            pygame.display.flip()

            self.clock.tick(60)

        pygame.quit()

    def display_health(self):
        font = pygame.font.Font(None, 36)
        text = font.render(f"Health: {self.player.health}", True, (255, 255, 255))
        self.screen.blit(text, (10, 10))

if __name__ == "__main__":
    game = Game()
    game.run()
