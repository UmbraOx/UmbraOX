import pygame
import sys

# Initialize Pygame
pygame.init()

# Constants
SCREEN_WIDTH = 800
SCREEN_HEIGHT = 600
FPS = 60

# Colors
WHITE = (255, 255, 255)
BLACK = (0, 0, 0)

# Game states
game_state = {
    'player_position': [100, 100],
    'health': 100,
    'enemy_position': [700, 300],
    'timer': 0
}

def reset_game():
    """Reset all game state to initial values."""
    global game_state
    game_state = {
        'player_position': [100, 100],
        'health': 100,
        'enemy_position': [700, 300],
        'timer': 0
    }

def main():
    """Main function to run the game."""
    screen = pygame.display.set_mode((SCREEN_WIDTH, SCREEN_HEIGHT))
    pygame.display.set_caption("Game Reset Example")
    clock = pygame.time.Clock()

    running = True
    while running:
        for event in pygame.event.get():
            if event.type == pygame.QUIT:
                running = False
            elif event.type == pygame.KEYDOWN:
                if event.key == pygame.K_r:
                    reset_game()

        # Update game state (placeholder)
        game_state['timer'] += 1

        # Draw everything
        screen.fill(WHITE)
        pygame.draw.rect(screen, BLACK, (game_state['player_position'][0], game_state['player_position'][1], 50, 50))
        pygame.draw.rect(screen, RED, (game_state['enemy_position'][0], game_state['enemy_position'][1], 50, 50))

        # Update the display
        pygame.display.flip()

        # Cap the frame rate
        clock.tick(FPS)

    pygame.quit()
    sys.exit()

if __name__ == "__main__":
    main()
