import requests
from bs4 import BeautifulSoup

def fetch_html(url):
    """
    Fetches the HTML content of the given URL.
    
    :param url: The URL of the webpage to fetch.
    :return: The HTML content as a string.
    :raises requests.RequestException: If there is an error fetching the page.
    """
    try:
        response = requests.get(url)
        response.raise_for_status()  # Raise an exception for HTTP errors
        return response.text
    except requests.RequestException as e:
        print(f"Error fetching {url}: {e}")
        return None

def parse_html(html):
    """
    Parses the HTML content to find headlines.
    
    :param html: The HTML content as a string.
    :return: A list of headline texts.
    """
    soup = BeautifulSoup(html, 'html.parser')
    headlines = []
    
    # Assuming BBC News has headlines in <h3> tags with class 'gs-c-promo-heading__title'
    for headline_tag in soup.find_all('h3', class_='gs-c-promo-heading__title'):
        headline = headline_tag.get_text(strip=True)
        if headline:
            headlines.append(headline)
    
    return headlines

def main():
    """
    Main function to fetch and parse BBC News headlines.
    """
    url = "https://www.bbc.com/news"
    html_content = fetch_html(url)
    
    if html_content:
        headlines = parse_html(html_content)
        print("BBC News Headlines:")
        for i, headline in enumerate(headlines, start=1):
            print(f"{i}. {headline}")

if __name__ == "__main__":
    main()
