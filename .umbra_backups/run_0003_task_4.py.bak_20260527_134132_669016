import os
import requests
from zipfile import ZipFile

def download_and_prepare_umbra(output_dir='umbra', url='https://example.com/umbra/latest.zip'):
    """
    Downloads the latest version of Umbra from the specified URL and prepares it for installation.
    
    Parameters:
    output_dir (str): The directory where the Umbra files will be extracted.
    url (str): The URL to download the latest version of Umbra.
    
    Returns:
    str: The path to the prepared Umbra directory.
    
    Raises:
    requests.exceptions.RequestException: If there is an error during the download process.
    zipfile.BadZipFile: If the downloaded file is not a valid zip archive.
    """
    try:
        # Ensure the output directory exists
        if not os.path.exists(output_dir):
            os.makedirs(output_dir)
        
        # Download the latest version of Umbra
        response = requests.get(url, stream=True)
        response.raise_for_status()  # Raise an exception for HTTP errors
        
        # Save the downloaded file to a temporary location
        zip_path = os.path.join(output_dir, 'umbra.zip')
        with open(zip_path, 'wb') as f:
            for chunk in response.iter_content(chunk_size=8192):
                f.write(chunk)
        
        # Extract the contents of the zip file
        with ZipFile(zip_path, 'r') as zip_ref:
            zip_ref.extractall(output_dir)
        
        # Clean up the temporary zip file
        os.remove(zip_path)
        
        return output_dir
    
    except requests.exceptions.RequestException as e:
        print(f"Error downloading Umbra: {e}")
        raise
    except zipfile.BadZipFile as e:
        print("The downloaded file is not a valid zip archive.")
        raise

# Example usage
if __name__ == "__main__":
    try:
        umbra_path = download_and_prepare_umbra()
        print(f"Umbra has been prepared for installation in {umbra_path}.")
    except Exception as e:
        print(f"An error occurred: {e}")
