def t_all_syn():
    broken=[]
    for fn in sorted(os.listdir(RD)):
        if fn.endswith(".py"):
            try: ast.parse(rd(os.path.join(RD,fn)))
            except SyntaxError as e: broken.append(fn+":"+str(e))
    assert not broken, str(broken[:3])
test("All core/runtime/*.py syntax clean",t_all_syn)
